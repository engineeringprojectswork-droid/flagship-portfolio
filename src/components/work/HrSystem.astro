---
import Spine from './spine/Spine.astro';
import Hook from './spine/Hook.astro';
import Brief from './spine/Brief.astro';
import Build from './spine/Build.astro';
import Proof from './spine/Proof.astro';
import Honesty from './spine/Honesty.astro';
import Pipeline from './centerpieces/Pipeline.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Brief artifact — the master-tracker funnel (verbatim from the prior story).
const funnel = [
  { w: '100%', d: '', count: 142, label: { en: 'Résumés parsed', ar: 'سِيَر مُحلَّلة' } },
  { w: '70%', d: 'd1', count: 100, label: { en: 'Deduped candidates', ar: 'مرشّحون بلا تكرار' } },
  { w: '30%', d: 'd2', count: 8, label: { en: 'Shortlisted', ar: 'القائمة المختصرة' } },
];

// Beat 3 · Build — "what I ran / built / owned", revealed one at a time on scrub.
const buildItems = [
  {
    n: '01',
    title: { en: 'Three channels → one tracker', ar: 'ثلاث قنوات ← مُتتبِّع واحد' },
    body: {
      en: 'Gmail, WhatsApp and file drops consolidated into a single colour-coded master tracker — one source of truth.',
      ar: 'Gmail وواتساب والملفات مُجمَّعة في مُتتبِّعٍ رئيسي واحد مُرمَّز بالألوان — مصدرٌ واحدٌ للحقيقة.',
    },
  },
  {
    n: '02',
    title: { en: 'Read-verified scoring', ar: 'تقييمٌ مُتحقَّقٌ بالقراءة' },
    body: {
      en: 'Each likely fit is read, not keyword-matched — which corrected at least 3 mis-rankings.',
      ar: 'كل مرشّحٍ مُحتمَل يُقرأ لا يُطابَق بالكلمات — ما صحّح ٣ أخطاء ترتيبٍ على الأقل.',
    },
  },
  {
    n: '03',
    title: { en: 'A daily cycle that runs itself', ar: 'دورة يومية تُدير نفسها' },
    body: {
      en: '08:30 intake, a read-only WhatsApp check every 5h, and a 19:30 archive — it runs whether I’m there or not.',
      ar: 'استقبال ٨:٣٠، وفحص واتساب للقراءة فقط كل ٥ ساعات، وأرشفة ١٩:٣٠ — يعمل سواءٌ كنتُ موجودًا أم لا.',
    },
  },
  {
    n: '04',
    title: { en: 'Strict rules, enforced', ar: 'قواعد صارمة، مُطبَّقة' },
    body: {
      en: 'Male-only shortlist for these roles, never message without approval, never invent data.',
      ar: 'قائمة مختصرة للذكور لهذه الأدوار، لا مراسلة دون موافقة، ولا اختلاق بيانات.',
    },
  },
];

const deliveryMetrics: MetricItem[] = [
  { count: 142, label: { en: 'Résumés parsed', ar: 'سِيَر مُحلَّلة' } },
  { count: 100, label: { en: 'Deduplicated candidates', ar: 'مرشّحون بلا تكرار' } },
  { count: 7, label: { en: 'Python scripts', ar: 'سكربتات بايثون' } },
  { count: 3, label: { en: 'Scheduled jobs live', ar: 'مهام مجدولة حيّة' } },
];

const tools = [
  'Python',
  'openpyxl',
  'cron / scheduled tasks',
  'Google Drive / Sheets',
  'Gmail',
  'WhatsApp Web (read-only)',
  'JSON / CSV',
];

// Verbatim honesty note (the bold lead-in is moved to the beat kicker).
const note = {
  en: 'Spec-driven, AI-assisted (Claude Code), operated daily by me — I set the roles, the rubric, the rules and the manager-review mode, and I approve every invitation. Time saved and recruiter-fee avoidance were never measured, so they aren’t claimed.',
  ar: 'مدفوعٌ بالمواصفات، وبمساعدة الذكاء الاصطناعي (Claude Code)، وأُشغّله يوميًا — وضعت الأدوار والمعايير والقواعد ووضع مراجعة المدير، وأوافق على كل دعوة. ولم يُقَس الوقت الموفّر ولا توفير أتعاب التوظيف، فلا يُدّعيان.',
};
---

<Spine lang={lang}>
  <Hook
    lang={lang}
    badge={{ en: 'Automation · Recruitment', ar: 'أتمتة · توظيف' }}
    headline={{
      en: 'Hiring on<br><span class="gradient-text">autopilot.</span>',
      ar: 'توظيفٌ<br><span class="gradient-text">يعمل تلقائيًا.</span>',
    }}
    lead={{
      en: 'Résumés arrive on three channels at once. <b>7 Python scripts and 3 scheduled jobs</b> collect, dedupe, read-score and track them daily — and never message a candidate without approval.',
      ar: 'السِّيَر تصل عبر ثلاث قنواتٍ معًا. <b>٧ سكربتات بايثون و٣ مهام مجدولة</b> تجمعها وتُزيل التكرار وتُقيّمها بالقراءة وتتتبّعها يوميًا — ولا تراسل مرشّحًا دون موافقة.',
    }}
    heroNumber="142 → 100"
    heroCaption={{ en: 'résumés parsed<br>→ deduped candidates', ar: 'سِيَر مُحلَّلة<br>← مرشّحون بلا تكرار' }}
    ghost="142"
  />

  <Brief
    lang={lang}
    kicker={{ en: 'The problem', ar: 'المشكلة' }}
    heading={{
      en: 'Keyword sorting hires the wrong person.',
      ar: 'الفرز بالكلمات يوظّف الشخص الخطأ.',
    }}
    body={{
      en: 'Applications piled up across Gmail, WhatsApp and a downloads folder; the same person applied twice; and keyword ranking once put a procurement officer first for an engineering role. The fix: read, don’t keyword-match — at scale.',
      ar: 'تكدّست الطلبات عبر Gmail وواتساب ومجلد التنزيلات؛ وتقدّم الشخص نفسه مرّتين؛ وذات مرّة وضع الترتيب بالكلمات موظّف مشترياتٍ أولًا لوظيفة هندسية. الحل: القراءة لا مطابقة الكلمات — وعلى نطاقٍ واسع.',
    }}
    ghostWord="142"
  >
    <div slot="aside" style="margin-top:22px">
      <TechRow lang={lang} items={['Gmail', 'WhatsApp']} center={false} />
    </div>
    <div class="device">
      <div class="device__bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="addr">Master tracker · daily</span>
      </div>
      <div class="device__body" style="padding:26px">
        <div class="funnel">
          {
            funnel.map((f) => (
              <div class={`fbar reveal${f.d ? ` ${f.d}` : ''}`} style={`--w:${f.w}`}>
                <span>{pick(lang, f.label)}</span>
                <b class="tnum" data-count={f.count} data-duration="1500">
                  0
                </b>
              </div>
            ))
          }
        </div>
        <p class="muted" style="font-size:12.5px;margin-top:16px">
          {
            pick(lang, {
              en: 'One build · 24 Jun 2026 · Gmail + WhatsApp + file drops',
              ar: 'بناءٌ واحد · ٢٤ يونيو ٢٠٢٦ · Gmail + واتساب + ملفات',
            })
          }
        </p>
      </div>
    </div>
  </Brief>

  <Build
    lang={lang}
    kicker={{ en: 'What I built', ar: 'ما الذي بنيته' }}
    heading={{ en: 'It runs whether I’m there or not.', ar: 'يعمل سواءٌ كنتُ موجودًا أم لا.' }}
    mult={2.6}
    items={buildItems}
  />

  <Proof lang={lang} center="pipeline" mult={2.4}>
    <Pipeline lang={lang} />
  </Proof>

  <section class="story-section section-glow proof-numbers">
    <div class="wrap">
      <Metrics
        lang={lang}
        eyebrow={{ en: 'One build · 24 Jun 2026', ar: 'بناءٌ واحد · ٢٤ يونيو ٢٠٢٦' }}
        items={deliveryMetrics}
      />
    </div>
  </section>

  <Honesty
    lang={lang}
    slug="hr-system"
    kicker={{ en: 'Honest credit', ar: 'نسبٌ صادق' }}
    note={note}
  >
    <div slot="tools" style="margin-top:22px">
      <TechRow lang={lang} items={tools} center={false} />
    </div>
  </Honesty>
</Spine>

<FilmEmbed
  lang={lang}
  film="hr-system.html"
  title={{ en: 'Hiring on autopilot — interactive story film', ar: 'فيلم القصة التفاعلي — التوظيف التلقائي' }}
/>

<style>
  .funnel {
    display: grid;
    gap: 12px;
  }
  .fbar {
    position: relative;
    border-radius: 12px;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border: 1px solid var(--panel-brd);
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
  }
  .fbar::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--grad);
    opacity: 0.18;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.2s var(--ease);
  }
  [dir='rtl'] .fbar::before {
    transform-origin: right;
  }
  .fbar.in::before {
    transform: scaleX(1);
  }
  .fbar b {
    font-size: 19px;
    font-weight: 800;
    position: relative;
  }
  .fbar span {
    position: relative;
    color: var(--ink-2);
    font-weight: 600;
    font-size: 14px;
  }
</style>
