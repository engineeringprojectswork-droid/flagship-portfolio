---
/**
 * Marked placeholder for a real screenshot (16:10 / 16:11 etc).
 * Renders the dashed + hatch + domain-glow placeholder until a real `src`
 * is supplied — then it drops in a cover image with no layout shift.
 */
import { pick, type Lang } from '../../../i18n/utils';

interface Props {
  lang: Lang;
  /** aspect ratio, e.g. "16/10" | "16/11" | "16/9" */
  ratio?: string;
  /** describes the real screenshot that belongs here */
  label: { en: string; ar: string };
  /** real image path once supplied (e.g. /img/work/meta-ads-ads-manager.png) */
  src?: string;
  alt?: string;
}
const { lang, ratio = '16/10', label, src, alt } = Astro.props;
const ratioLabel = ratio.replace('/', ':');
---

<div class="asset-slot" style={`aspect-ratio:${ratio}`}>
  {
    src ? (
      <img src={src} alt={alt ?? pick(lang, label)} loading="lazy" decoding="async" />
    ) : (
      <div class="asset-slot__txt">
        <span class="mark" aria-hidden="true">▦</span>
        <span class="sub">{pick(lang, label)} · {ratioLabel}</span>
      </div>
    )
  }
</div>
