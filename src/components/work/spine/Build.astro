---
/** Beat 3 · Build — PINNED + SCRUBBED. The "what I ran / owned" items reveal
 *  one at a time as the pin scrubs (lib/storyscroll.ts steps [data-build-item]).
 *  data-mult sets the scroll length: pin distance = (mult-1) * 100vh. */
import { pick, type Lang } from '../../../i18n/utils';

interface BuildItem {
  n: string;
  title: { en: string; ar: string };
  body: { en: string; ar: string };
}
interface Props {
  lang: Lang;
  kicker: { en: string; ar: string };
  heading: { en: string; ar: string };
  intro?: { en: string; ar: string };
  /** pin length multiplier (default 2.6) */
  mult?: number;
  items: BuildItem[];
}
const { lang, kicker, heading, intro, mult = 2.6, items } = Astro.props;
---

<section class="beat beat--build" data-build data-mult={mult.toString()}>
  <div class="beat__sticky" data-build-sticky>
    <div class="build__grid">
      <div class="build__head reveal">
        <span class="kicker">{pick(lang, kicker)}</span>
        <h2>{pick(lang, heading)}</h2>
        {intro && <p>{pick(lang, intro)}</p>}
        <div class="build__bar"><i data-build-bar></i></div>
      </div>
      <div class="build__items">
        {
          items.map((it) => (
            <div class="build__item" data-build-item>
              <span class="n">{it.n}</span>
              <div>
                <h4>{pick(lang, it.title)}</h4>
                <p>{pick(lang, it.body)}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
