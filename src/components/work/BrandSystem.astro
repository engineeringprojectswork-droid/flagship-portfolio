---
import StoryHero from './StoryHero.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// NOTE: the ad-creative image gallery (mosaic) was removed for now — the
// presentation will be redesigned later. The images remain in public/img/work/.

const feats = [
  {
    ic: '◑',
    h: { en: 'Design tokens & UI kits', ar: 'رموز التصميم وأطقم الواجهة' },
    p: {
      en: 'Reusable kits for social ads, the WhatsApp catalog, and OpenSooq.',
      ar: 'أطقم قابلة لإعادة الاستخدام لإعلانات السوشيال وكتالوج واتساب وOpenSooq.',
    },
  },
  {
    ic: '▭',
    h: { en: '18 HTML preview pages', ar: '١٨ صفحة معاينة HTML' },
    p: {
      en: 'The system, previewable — so every asset stays on-brand.',
      ar: 'النظام قابلٌ للمعاينة — ليبقى كل عنصرٍ مطابقًا للهوية.',
    },
  },
  {
    ic: '▥',
    h: { en: 'A 10-page A4 print catalog', ar: 'كتالوج طباعة A4 من ١٠ صفحات' },
    p: {
      en: 'Print-ready, bilingual, fully laid out.',
      ar: 'جاهز للطباعة، ثنائي اللغة، بتنسيقٍ كامل.',
    },
  },
];

const outputMetrics: MetricItem[] = [
  { count: 254, prefix: '~', label: { en: 'Production files', ar: 'ملفات إنتاج' } },
  { count: 144, prefix: '~', label: { en: 'Videos', ar: 'مقاطع فيديو' } },
  { count: 18, label: { en: 'Brand preview pages', ar: 'صفحات معاينة الهوية' } },
  { count: 10, label: { en: 'Page print catalog', ar: 'صفحات كتالوج طباعة' } },
];

const howMade = {
  en: '<b>How it was made:</b> Canva, After Effects and Premiere for design and motion; AI video (Kling, Wan) on rented GPUs for ad concepts; and AI restoration of hundreds of legacy project photos. The file and video counts come from the company’s production archive.',
  ar: '<b>كيف صُنع:</b> Canva وAfter Effects وPremiere للتصميم والموشن؛ وفيديو الذكاء الاصطناعي (Kling وWan) على معالجاتٍ مستأجرة لمفاهيم الإعلانات؛ وترميمٌ بالذكاء الاصطناعي لمئات صور المشاريع القديمة. وأعداد الملفات والفيديو من أرشيف إنتاج الشركة.',
};

const tools = [
  'Canva',
  'After Effects',
  'Premiere',
  'Kling',
  'Wan',
  'ComfyUI',
  { en: 'Rented GPUs', ar: 'معالجات مستأجرة' },
];
---

<StoryHero
  lang={lang}
  badge={{ en: 'Brand & Content', ar: 'الهوية والمحتوى' }}
  headline={{
    en: 'A whole<br><span class="gradient-text">content engine.</span>',
    ar: 'محرّك محتوى<br><span class="gradient-text">متكامل.</span>',
  }}
  lead={{
    en: 'Around <b style="color:var(--ink)">254 production files — including ~144 videos</b> — plus a complete bilingual brand system. One person, the output of a studio.',
    ar: 'نحو <b style="color:var(--ink)">٢٥٤ ملف إنتاج — منها ~١٤٤ فيديو</b> — إضافةً إلى نظام هويةٍ ثنائي اللغة كامل. شخصٌ واحد، بإنتاج استوديو.',
  }}
/>

<FilmEmbed
  lang={lang}
  film="brand-system.html"
  title={{ en: 'Interactive story film', ar: 'قصة تفاعلية' }}
/>

<!-- THE FLAGSHIP -->
<section class="story-section">
  <div class="wrap two-col">
    <div class="stack">
      <p class="kicker reveal">{pick(lang, { en: 'The flagship', ar: 'العمل الأبرز' })}</p>
      <h2 class="h-lg reveal d1">
        {pick(lang, { en: 'The Niagara Fog brand system', ar: 'نظام هوية Niagara Fog' })}
      </h2>
      <p class="lead reveal d2">
        {pick(lang, {
          en: 'For the misting line I built a complete bilingual design system — not just posts, but the rules everything is made from.',
          ar: 'لخطّ الترذيذ بنيت نظام تصميمٍ ثنائي اللغة كامل — لا مجرّد منشورات، بل القواعد التي يُصنع منها كل شيء.',
        })}
      </p>
    </div>
    <div class="feat-list reveal d1">
      {
        feats.map((f) => (
          <div class="feat">
            <div class="ic">{f.ic}</div>
            <div>
              <h4>{f.h[lang]}</h4>
              <p>{f.p[lang]}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- THE OUTPUT -->
<section class="story-section section-glow">
  <div class="wrap">
    <Metrics
      lang={lang}
      eyebrow={{ en: 'The output', ar: 'المُخرَجات' }}
      items={outputMetrics}
    />
    <div class="note reveal" style="margin-top:30px" set:html={howMade[lang]}></div>
  </div>
</section>

<!-- TOOLS -->
<section class="story-section">
  <div class="wrap center stack" style="max-width:760px;margin-inline:auto">
    <p class="kicker reveal">{pick(lang, { en: 'Tools', ar: 'الأدوات' })}</p>
    <TechRow lang={lang} items={tools} />
  </div>
</section>
