---
import Spine from './spine/Spine.astro';
import Hook from './spine/Hook.astro';
import Brief from './spine/Brief.astro';
import Build from './spine/Build.astro';
import Proof from './spine/Proof.astro';
import Honesty from './spine/Honesty.astro';
import Mosaic from './centerpieces/Mosaic.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Beat 2 · Brief artifact — the three flagship deliverables, as a stat card.
const feats = [
  {
    ic: '◑',
    h: { en: 'Design tokens & UI kits', ar: 'رموز التصميم وأطقم الواجهة' },
    p: {
      en: 'Reusable kits for social ads, the WhatsApp catalog, and OpenSooq.',
      ar: 'أطقم قابلة لإعادة الاستخدام لإعلانات السوشيال وكتالوج واتساب وOpenSooq.',
    },
  },
  {
    ic: '▭',
    h: { en: '18 HTML preview pages', ar: '١٨ صفحة معاينة HTML' },
    p: {
      en: 'The system, previewable — so every asset stays on-brand.',
      ar: 'النظام قابلٌ للمعاينة — ليبقى كل عنصرٍ مطابقًا للهوية.',
    },
  },
  {
    ic: '▥',
    h: { en: 'A 10-page A4 print catalog', ar: 'كتالوج طباعة A4 من ١٠ صفحات' },
    p: {
      en: 'Print-ready, bilingual, fully laid out.',
      ar: 'جاهز للطباعة، ثنائي اللغة، بتنسيقٍ كامل.',
    },
  },
];

// Beat 3 · Build — "what I built", revealed one at a time on scrub.
const buildItems = [
  {
    n: '01',
    title: { en: 'Design tokens & UI kits', ar: 'رموز التصميم وأطقم الواجهة' },
    body: {
      en: 'Reusable kits for social ads, the WhatsApp catalog, and OpenSooq — the rules everything is made from.',
      ar: 'أطقم قابلة لإعادة الاستخدام لإعلانات السوشيال وكتالوج واتساب وOpenSooq — القواعد التي يُصنع منها كل شيء.',
    },
  },
  {
    n: '02',
    title: { en: '18 HTML preview pages', ar: '١٨ صفحة معاينة HTML' },
    body: {
      en: 'The system, previewable — so every asset stays on-brand.',
      ar: 'النظام قابلٌ للمعاينة — ليبقى كل عنصرٍ مطابقًا للهوية.',
    },
  },
  {
    n: '03',
    title: { en: 'A 10-page A4 print catalog', ar: 'كتالوج طباعة A4 من ١٠ صفحات' },
    body: {
      en: 'Print-ready, bilingual, fully laid out.',
      ar: 'جاهز للطباعة، ثنائي اللغة، بتنسيقٍ كامل.',
    },
  },
  {
    n: '04',
    title: { en: '~254 files · ~144 videos', ar: '~٢٥٤ ملفًا · ~١٤٤ فيديو' },
    body: {
      en: 'Canva, After Effects and Premiere; AI video (Kling, Wan) on rented GPUs; AI restoration of hundreds of legacy photos.',
      ar: 'Canva وAfter Effects وPremiere؛ وفيديو الذكاء الاصطناعي (Kling وWan) على معالجاتٍ مستأجرة؛ وترميمٌ بالذكاء الاصطناعي لمئات الصور القديمة.',
    },
  },
];

const outputMetrics: MetricItem[] = [
  { count: 254, prefix: '~', label: { en: 'Production files', ar: 'ملفات إنتاج' } },
  { count: 144, prefix: '~', label: { en: 'Videos', ar: 'مقاطع فيديو' } },
  { count: 18, label: { en: 'Brand preview pages', ar: 'صفحات معاينة الهوية' } },
  { count: 10, label: { en: 'Page print catalog', ar: 'صفحات كتالوج طباعة' } },
];

const tools = [
  'Canva',
  'After Effects',
  'Premiere',
  'Kling',
  'Wan',
  'ComfyUI',
  { en: 'Rented GPUs', ar: 'معالجات مستأجرة' },
];

// Verbatim honesty note — the bold lead-in ("How it was made:") moves to the
// beat kicker; the rest is the original copy unchanged.
const note = {
  en: 'Canva, After Effects and Premiere for design and motion; AI video (Kling, Wan) on rented GPUs for ad concepts; and AI restoration of hundreds of legacy project photos. The file and video counts come from the company’s production archive.',
  ar: 'Canva وAfter Effects وPremiere للتصميم والموشن؛ وفيديو الذكاء الاصطناعي (Kling وWan) على معالجاتٍ مستأجرة لمفاهيم الإعلانات؛ وترميمٌ بالذكاء الاصطناعي لمئات صور المشاريع القديمة. وأعداد الملفات والفيديو من أرشيف إنتاج الشركة.',
};
---

<Spine lang={lang}>
  <Hook
    lang={lang}
    badge={{ en: 'Brand & Content', ar: 'الهوية والمحتوى' }}
    headline={{
      en: 'A whole<br><span class="gradient-text">content engine.</span>',
      ar: 'محرّك محتوى<br><span class="gradient-text">متكامل.</span>',
    }}
    lead={{
      en: 'Around <b>254 production files — including ~144 videos</b> — plus a complete bilingual brand system. One person, the output of a studio.',
      ar: 'نحو <b>٢٥٤ ملف إنتاج — منها ~١٤٤ فيديو</b> — إضافةً إلى نظام هويةٍ ثنائي اللغة كامل. شخصٌ واحد، بإنتاج استوديو.',
    }}
    heroNumber="~254 files"
    heroCaption={{ en: 'production files<br>~144 of them video', ar: 'ملف إنتاج<br>~١٤٤ منها فيديو' }}
    ghost="254"
  />

  <Brief
    lang={lang}
    kicker={{ en: 'The flagship', ar: 'العمل الأبرز' }}
    heading={{ en: 'The Niagara Fog brand system', ar: 'نظام هوية Niagara Fog' }}
    body={{
      en: 'For the misting line I built a complete bilingual design system — not just posts, but the rules everything is made from.',
      ar: 'لخطّ الترذيذ بنيت نظام تصميمٍ ثنائي اللغة كامل — لا مجرّد منشورات، بل القواعد التي يُصنع منها كل شيء.',
    }}
    ghostWord="Niagara Fog"
  >
    <div slot="aside" style="margin-top:22px">
      <TechRow lang={lang} items={['Canva', 'After Effects', 'Premiere']} center={false} />
    </div>
    <div class="device">
      <div class="device__bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="addr">{pick(lang, { en: 'brand-system / preview', ar: 'نظام-الهوية / معاينة' })}</span>
      </div>
      <div class="device__body" style="padding:22px">
        <div class="feat-list">
          {
            feats.map((f) => (
              <div class="feat">
                <div class="ic">{f.ic}</div>
                <div>
                  <h4>{pick(lang, f.h)}</h4>
                  <p>{pick(lang, f.p)}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Brief>

  <Build
    lang={lang}
    kicker={{ en: 'What I built', ar: 'ما الذي بنيته' }}
    heading={{ en: 'One person, the output of a studio.', ar: 'شخصٌ واحد، بإنتاج استوديو.' }}
    mult={2.6}
    items={buildItems}
  />

  <Proof lang={lang} center="mosaic" mult={2.4}>
    <Mosaic lang={lang} />
  </Proof>

  <section class="story-section section-glow proof-numbers">
    <div class="wrap">
      <Metrics lang={lang} eyebrow={{ en: 'The output', ar: 'المُخرَجات' }} items={outputMetrics} />
    </div>
  </section>

  <Honesty
    lang={lang}
    slug="brand-system"
    kicker={{ en: 'How it was made', ar: 'كيف صُنع' }}
    note={note}
  >
    <div slot="tools" style="margin-top:22px">
      <TechRow lang={lang} items={tools} center={false} />
    </div>
  </Honesty>
</Spine>

<FilmEmbed
  lang={lang}
  film="brand-system.html"
  title={{ en: 'Brand system — interactive story film', ar: 'فيلم القصة التفاعلي — نظام الهوية' }}
/>