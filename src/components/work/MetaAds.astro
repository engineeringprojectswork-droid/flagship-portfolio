---
import Spine from './spine/Spine.astro';
import Hook from './spine/Hook.astro';
import Brief from './spine/Brief.astro';
import Build from './spine/Build.astro';
import Proof from './spine/Proof.astro';
import Honesty from './spine/Honesty.astro';
import CostFall from './centerpieces/CostFall.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const funnel = [
  { w: '100%', d: '', count: 85132, label: { en: 'Impressions', ar: 'ظهور' } },
  { w: '62%', d: 'd1', count: 40460, label: { en: 'Reach', ar: 'وصول' } },
  { w: '26%', d: 'd2', count: 206, label: { en: 'WhatsApp leads', ar: 'عملاء واتساب' } },
];

// Beat 3 · Build — "what I ran" items, revealed one at a time on scrub.
const buildItems = [
  {
    n: '01',
    title: { en: 'Click-to-WhatsApp lead ads', ar: 'إعلانات تواصل عبر واتساب' },
    body: {
      en: 'Campaign structure built around the one action that matters here: starting a chat.',
      ar: 'هيكل حملات مبنيّ حول الإجراء الأهم هنا: بدء محادثة.',
    },
  },
  {
    n: '02',
    title: { en: 'Audience & placement analysis', ar: 'تحليل الجمهور والمواضع' },
    body: {
      en: 'From Meta CSV exports: IG Stories cheapest, Feed costliest, buyers skewing male 25–54.',
      ar: 'من تصدير ميتا: ستوري إنستغرام الأرخص، والفيد الأغلى، والمشترون ذكور ٢٥–٥٤ غالبًا.',
    },
  },
  {
    n: '03',
    title: { en: 'A 30-day campaign plan (v2.0)', ar: 'خطة حملة ٣٠ يومًا (الإصدار ٢)' },
    body: {
      en: "$500 / 30-day budget, 3 ad sets, 80/20 FB/IG split — grounded in the account's real prior-year data.",
      ar: 'ميزانية ٥٠٠$ لـ٣٠ يومًا، و٣ مجموعات إعلانية، وتقسيم ٨٠/٢٠ فيسبوك/إنستغرام — مبنية على بيانات الحساب الفعلية للعام السابق.',
    },
  },
  {
    n: '04',
    title: { en: 'Cost-per-lead optimization', ar: 'تحسين تكلفة العميل' },
    body: {
      en: "Cut waste (flagged the account's worst ad at $6.25/call) and pushed the best campaign to $0.50/lead.",
      ar: 'قلّصت الهدر (رصدت أسوأ إعلان بـ٦٫٢٥$ للمكالمة) ودفعت أفضل حملة إلى ٠٫٥٠$ للعميل.',
    },
  },
];

const primaryMetrics: MetricItem[] = [
  { count: 0.84, decimals: 2, prefix: '$', label: { en: 'Cost per WhatsApp lead', ar: 'تكلفة العميل عبر واتساب' } },
  { count: 206, label: { en: 'Leads / conversations', ar: 'عملاء / محادثات' } },
  { count: 172.78, decimals: 2, prefix: '$', label: { en: 'Total ad spend', ar: 'إجمالي الإنفاق' } },
  {
    count: 0.5,
    decimals: 2,
    prefix: '$',
    label: { en: 'Best campaign / lead', ar: 'أفضل حملة / عميل' },
    sub: { en: 'Misting Fan · 106 leads', ar: 'مروحة الرذاذ · ١٠٦ عملاء' },
  },
];

const secondaryMetrics = [
  { count: '85132', text: '0', label: { en: 'Impressions', ar: 'ظهور' } },
  { count: '40460', text: '0', label: { en: 'Reach', ar: 'وصول' } },
  { count: '0.65', decimals: '2', suffix: '%', text: '0', label: 'CTR' },
  { count: '2.03', decimals: '2', prefix: '$', text: '$0', label: 'CPM' },
];

const tools = [
  { en: 'Meta Ads Manager', ar: 'Meta Ads Manager' },
  { en: 'Click-to-WhatsApp', ar: 'Click-to-WhatsApp' },
  { en: 'A/B testing', ar: 'A/B testing' },
  { en: 'CSV breakdown analysis', ar: 'تحليل CSV' },
  { en: 'CPM / CPC / CPL', ar: 'CPM / CPC / CPL' },
  { en: 'Bilingual CRM link', ar: 'ربط بنظام العملاء' },
];

// Verbatim honesty note (lead-in moved to the beat kicker to avoid duplication).
const note = {
  en: "The figures above are the measured 2026 pilot (1 May–3 Jun), read from the live CRM. I generate the leads — the company's engineer prices and closes — so I report leads, not closed revenue. Across an earlier 2024–2025 run my ad export self-reports ~793K impressions and 214 calls at ~$3.12 each; combined that's roughly 878K impressions and 420+ leads.",
  ar: 'الأرقام أعلاه هي تجربة ٢٠٢٦ المُقاسة (١ مايو–٣ يونيو) من نظام العملاء الحيّ. أنا أُولّد العملاء المحتملين — ومهندس الشركة يُسعّر ويُغلق — لذا أُبلّغ عن العملاء لا عن الإيرادات المُغلقة. وفي فترة سابقة ٢٠٢٤–٢٠٢٥ يذكر تصدير إعلاناتي ذاتيًا نحو ٧٩٣ ألف ظهور و٢١٤ مكالمة بنحو ٣٫١٢$ للواحدة؛ ومجتمعةً نحو ٨٧٨ ألف ظهور و٤٢٠+ عميلًا.',
};
---

<Spine lang={lang}>
  <Hook
    lang={lang}
    badge={{ en: 'Paid Social · Meta Ads', ar: 'الإعلانات المدفوعة · ميتا' }}
    headline={{
      en: 'Leads under<br><span class="gradient-text">a dollar.</span>',
      ar: 'عملاء بأقلّ<br><span class="gradient-text">من دولار.</span>',
    }}
    lead={{
      en: 'A measured Meta pilot for a B2B industrial supplier: I turned $172.78 of spend into 206 WhatsApp conversations — at about <b>$0.84 each</b>.',
      ar: 'تجربة ميتا مُقاسة لمورّد صناعي B2B: حوّلت إنفاقًا قدره ١٧٢٫٧٨$ إلى ٢٠٦ محادثة واتساب — بنحو <b>٠٫٨٤$ للواحدة</b>.',
    }}
    heroNumber="$0.84"
    heroCaption={{ en: 'cost per<br>WhatsApp lead', ar: 'تكلفة كل<br>عميل واتساب' }}
    ghost="$"
  />

  <Brief
    lang={lang}
    kicker={{ en: 'The brief', ar: 'المهمة' }}
    heading={{ en: 'Industrial products. A WhatsApp-first market.', ar: 'منتجات صناعية. وسوقٌ يبدأ من واتساب.' }}
    body={{
      en: 'Misting fans, access equipment, scaffolding — sold B2B in Kuwait, where buyers want to chat, not fill forms. The job: get qualified WhatsApp conversations as cheaply as possible, and prove every dinar.',
      ar: 'مراوح رذاذ، ومعدات وصول، وسقالات — تُباع B2B في الكويت، حيث يفضّل المشترون المحادثة لا تعبئة النماذج. المطلوب: محادثات واتساب مؤهّلة بأقل تكلفة ممكنة، مع إثبات كل دينار.',
    }}
    ghostWord="WhatsApp"
  >
    <div slot="aside" style="margin-top:22px">
      <TechRow lang={lang} items={['Meta Ads', 'WhatsApp', 'Click-to-WhatsApp']} center={false} />
    </div>
    <div class="device">
      <div class="device__bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="addr">Meta Ads Manager</span>
      </div>
      <div class="device__body" style="padding:26px">
        <div class="funnel">
          {
            funnel.map((f) => (
              <div class={`fbar reveal${f.d ? ` ${f.d}` : ''}`} style={`--w:${f.w}`}>
                <span>{pick(lang, f.label)}</span>
                <b class="tnum" data-count={f.count} data-duration="1700">
                  0
                </b>
              </div>
            ))
          }
        </div>
        <p class="muted" style="font-size:12.5px;margin-top:16px">
          {
            pick(lang, {
              en: '2026 pilot · 1 May – 3 Jun · sourced from the live CRM',
              ar: 'تجربة ٢٠٢٦ · ١ مايو – ٣ يونيو · من نظام العملاء الحيّ',
            })
          }
        </p>
      </div>
    </div>
  </Brief>

  <Build
    lang={lang}
    kicker={{ en: 'What I ran', ar: 'ما الذي أدرته' }}
    heading={{ en: 'Owned end-to-end.', ar: 'أُدير من الألف إلى الياء.' }}
    mult={2.6}
    items={buildItems}
  />

  <Proof lang={lang} center="cost-fall" mult={2.4}>
    <CostFall lang={lang} />
  </Proof>

  <section class="story-section section-glow proof-numbers">
    <div class="wrap">
      <Metrics lang={lang} eyebrow={{ en: 'The numbers · 2026 pilot', ar: 'الأرقام · تجربة ٢٠٢٦' }} items={primaryMetrics} />
      <div class="metrics" style="margin-top:18px">
        {
          secondaryMetrics.map((m, i) => (
            <div class={`metric reveal${i ? ` d${i}` : ''}`}>
              <div class="metric__num tnum" data-count={m.count} data-decimals={m.decimals} data-prefix={m.prefix} data-suffix={m.suffix}>
                {m.text}
              </div>
              <div class="metric__lbl">{typeof m.label === 'string' ? m.label : pick(lang, m.label)}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Honesty
    lang={lang}
    slug="meta-ads"
    kicker={{ en: 'Straight about the numbers', ar: 'بصراحة عن الأرقام' }}
    note={note}
  >
    <div slot="tools" style="margin-top:22px">
      <TechRow lang={lang} items={tools} center={false} />
    </div>
  </Honesty>
</Spine>

<FilmEmbed lang={lang} film="meta-ads.html" title={{ en: 'Meta ads — interactive story film', ar: 'فيلم القصة التفاعلي — ميتا' }} />

<style>
  .funnel {
    display: grid;
    gap: 12px;
  }
  .fbar {
    position: relative;
    border-radius: 12px;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border: 1px solid var(--panel-brd);
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
  }
  .fbar::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--grad);
    opacity: 0.18;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.2s var(--ease);
  }
  [dir='rtl'] .fbar::before {
    transform-origin: right;
  }
  .fbar.in::before {
    transform: scaleX(1);
  }
  .fbar b {
    font-size: 19px;
    font-weight: 800;
    position: relative;
  }
  .fbar span {
    position: relative;
    color: var(--ink-2);
    font-weight: 600;
    font-size: 14px;
  }
</style>
