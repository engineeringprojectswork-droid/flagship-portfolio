---
/** Centerpiece · hr-system — "the pipeline" 142 → 100.
 *  Résumés flow through 3 channels (Gmail / WhatsApp / file drops) → dedupe →
 *  score → resolves to "142 → 100". Nodes + edges light up IN SEQUENCE as the
 *  proof pin scrubs: each stage keys its opacity/scale to a threshold of --q
 *  (pure CSS — no JS). --q=0 is the start, --q=1 the readable end-state.
 *  The engine (lib/storyscroll.ts) only sets --q on the proof section; this
 *  centerpiece is entirely CSS-driven off it. */
import { pick, type Lang } from '../../../i18n/utils';
import AssetSlot from '../spine/AssetSlot.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Three intake channels — each keyed to an early --q threshold so they light
// up first, in sequence. --t is the progress point at which the node resolves.
const sources = [
  { txt: 'Gmail', t: '0.04' },
  { txt: 'WhatsApp', t: '0.12' },
  { txt: { en: 'File drops', ar: 'ملفات' }, t: '0.20' },
];
---

<div class="proof__grid pipe">
  <div class="pipe__copy reveal">
    <span class="kicker">{pick(lang, { en: 'The pipeline', ar: 'خط المعالجة' })}</span>
    <h2>{pick(lang, { en: '142 → 100, daily.', ar: '١٤٢ ← ١٠٠، يوميًا.' })}</h2>
    <p>
      {
        pick(lang, {
          en: 'Three channels in. Deduped, then read-scored. 142 résumés resolve to 100 unique candidates — every run.',
          ar: 'ثلاث قنواتٍ للدخل. تُنقّى ثم تُقيَّم بالقراءة. ١٤٢ سيرة تنتهي إلى ١٠٠ مرشّحٍ فريد — في كل تشغيل.',
        })
      }
    </p>
    <div class="pipe__shot">
      <AssetSlot
        lang={lang}
        ratio="16/10"
        label={{ en: 'Master tracker — colour-coded', ar: 'المُتتبِّع الرئيسي — مُرمَّز بالألوان' }}
      />
    </div>
  </div>

  <div class="pipe__stage" aria-hidden="true">
    <!-- intake channels -->
    <div class="pipe__col pipe__col--src">
      {
        sources.map((s) => (
          <span class="pipe__node pipe__src" style={`--t:${s.t}`}>
            <bdi>{typeof s.txt === 'string' ? s.txt : pick(lang, s.txt)}</bdi>
          </span>
        ))
      }
    </div>

    <!-- channels → dedupe -->
    <span class="pipe__edge pipe__edge--in" style="--t:0.24"></span>

    <!-- dedupe -->
    <div class="pipe__col pipe__col--mid">
      <span class="pipe__node pipe__op" style="--t:0.34">
        <b>142</b>
        <span class="pipe__op-lbl">{pick(lang, { en: 'dedupe', ar: 'إزالة التكرار' })}</span>
      </span>
    </div>

    <!-- dedupe → score -->
    <span class="pipe__edge pipe__edge--mid" style="--t:0.50"></span>

    <!-- score -->
    <div class="pipe__col pipe__col--mid">
      <span class="pipe__node pipe__op" style="--t:0.60">
        <b>★</b>
        <span class="pipe__op-lbl">{pick(lang, { en: 'read-score', ar: 'تقييم بالقراءة' })}</span>
      </span>
    </div>

    <!-- score → result -->
    <span class="pipe__edge pipe__edge--out" style="--t:0.72"></span>

    <!-- resolved end-state -->
    <div class="pipe__col pipe__col--end">
      <span class="pipe__result" style="--t:0.82">
        <b class="pipe__num"><bdi>142 → 100</bdi></b>
        <span class="pipe__cap">{pick(lang, { en: 'parsed → deduped', ar: 'مُحلَّلة ← بلا تكرار' })}</span>
      </span>
    </div>
  </div>
</div>

<style>
  .pipe {
    align-items: center;
  }
  .pipe__copy h2 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.04;
    margin: 14px 0 14px;
  }
  [dir='rtl'] .pipe__copy h2 {
    letter-spacing: 0;
  }
  .pipe__copy p {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
    max-width: 380px;
  }
  .pipe__shot {
    margin-top: 24px;
    max-width: 420px;
    border: 1px solid var(--hair);
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface-raised);
  }

  /* ---- the staged pipeline (CSS-only off --q) ----
     --q is inherited from the [data-proof] section (engine drives 0 → 1).
     Do NOT redeclare it here, or it would shadow the engine value. The
     fallback media queries below force it to the static end-state (=1). */
  .pipe__stage {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 8px 0;
  }
  .pipe__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pipe__col--src {
    gap: 10px;
  }

  /* Each node/edge resolves as --q passes its --t threshold.
     k = clamp(0, (q - t) * 9, 1) → off below t, full a little past it. */
  .pipe__node,
  .pipe__result {
    --k: clamp(0, (var(--q, 1) - var(--t)) * 9, 1);
    opacity: calc(0.16 + 0.84 * var(--k));
    transform: scale(calc(0.92 + 0.08 * var(--k)));
    transform-origin: center;
    will-change: opacity, transform;
  }

  .pipe__node {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    align-self: flex-start;
    padding: 11px 15px;
    border-radius: 12px;
    background: var(--surface-card);
    border: 1px solid var(--hair);
    color: var(--ink);
    font-weight: 600;
    font-size: 14px;
  }
  .pipe__src {
    font-family: var(--font-mono);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--hair));
  }
  .pipe__src::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    flex: 0 0 auto;
  }

  .pipe__op {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-card));
  }
  .pipe__op b {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    direction: ltr;
    unicode-bidi: isolate;
    min-width: 28px;
    text-align: center;
  }
  .pipe__op-lbl {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  /* connecting edges — a hairline that "fills" with the accent as --q passes --t */
  .pipe__edge {
    position: relative;
    align-self: flex-start;
    inset-inline-start: 22px;
    width: 2px;
    height: 22px;
    background: color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 2px;
    overflow: hidden;
  }
  .pipe__edge::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: calc(clamp(0, (var(--q, 1) - var(--t)) * 9, 1) * 100%);
    background: linear-gradient(var(--accent-2), var(--accent));
    border-radius: 2px;
  }

  /* the resolved 142 → 100 end card */
  .pipe__result {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-self: flex-start;
    margin-top: 6px;
    padding: 16px 20px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 14%, var(--surface-card));
  }
  .pipe__num {
    font-size: clamp(34px, 6vw, 58px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .pipe__num bdi {
    direction: ltr;
    unicode-bidi: isolate;
  }
  .pipe__cap {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  /* fallbacks: neutralise the scrub to the static end-state */

  @media (max-width: 820px) {
  }
</style>
