---
/** Centerpiece · brand-system — "the content galaxy".
 *  ~254 production files / ~144 videos drift in layered depths; as the proof
 *  pin scrubs (--q 0→1) the scattered tiles converge into a clean grid and the
 *  count snaps into focus. Pure-CSS off --q (no JS). AssetSlot tiles are marked
 *  placeholders — no fabricated thumbnails. */
import AssetSlot from '../spine/AssetSlot.astro';
import { pick, type Lang } from '../../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Scattered start → grid end. Each tile carries a depth + a start offset that
// CSS lerps toward 0 as --q rises. dx/dy in px (RTL flips dx via the wrapper).
const tiles = [
  { ratio: '16/10', depth: 1.15, dx: -42, dy: -64, rot: -7, label: { en: 'Social ad creative', ar: 'إعلان سوشيال' } },
  { ratio: '1/1', depth: 0.7, dx: 50, dy: -40, rot: 6, label: { en: 'WhatsApp catalog card', ar: 'بطاقة كتالوج واتساب' } },
  { ratio: '16/10', depth: 0.95, dx: -56, dy: 48, rot: 5, label: { en: 'AI ad concept (Kling/Wan)', ar: 'مفهوم إعلان AI (Kling/Wan)' } },
  { ratio: '1/1', depth: 1.3, dx: 60, dy: 58, rot: -8, label: { en: 'Restored legacy photo', ar: 'صورة قديمة مُرمَّمة' } },
  { ratio: '16/10', depth: 0.55, dx: 4, dy: -78, rot: 3, label: { en: 'Print catalog spread', ar: 'صفحة كتالوج طباعة' } },
  { ratio: '1/1', depth: 0.85, dx: 8, dy: 80, rot: -4, label: { en: 'Brand preview page', ar: 'صفحة معاينة الهوية' } },
];
---

<div class="proof__grid mosaic">
  <div class="mosaic__copy reveal">
    <span class="kicker">{pick(lang, { en: 'The proof · the archive', ar: 'الإثبات · الأرشيف' })}</span>
    <h2>
      <b class="mosaic__big tnum"><bdi>~254</bdi></b>
      <span>{pick(lang, { en: 'production files, assembled.', ar: 'ملف إنتاج، مُجمَّعة.' })}</span>
    </h2>
    <p>
      {
        pick(lang, {
          en: 'Around 144 of them videos — drifting in from a studio-scale archive into one coherent, on-brand system.',
          ar: 'نحو ١٤٤ منها مقاطع فيديو — تنجمع من أرشيفٍ بحجم استوديو إلى نظامٍ واحدٍ متماسك ومطابق للهوية.',
        })
      }
    </p>
    <div class="mosaic__legend">
      <span><b class="tnum"><bdi>~144</bdi></b> {pick(lang, { en: 'videos', ar: 'فيديو' })}</span>
      <span><b class="tnum"><bdi>18</bdi></b> {pick(lang, { en: 'preview pages', ar: 'صفحة معاينة' })}</span>
      <span><b class="tnum"><bdi>10</bdi></b> {pick(lang, { en: 'page catalog', ar: 'صفحات كتالوج' })}</span>
    </div>
  </div>

  <div class="mosaic__wall" aria-hidden="true">
    {
      tiles.map((t) => (
        <div
          class="mosaic__tile"
          style={`--depth:${t.depth};--dx:${t.dx}px;--dy:${t.dy}px;--rot:${t.rot}deg`}
        >
          <AssetSlot lang={lang} ratio={t.ratio} label={t.label} />
        </div>
      ))
    }
  </div>
</div>

<style>
  .mosaic {
    align-items: center;
  }
  .mosaic__copy h2 {
    font-size: clamp(26px, 3.6vw, 44px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.06;
    margin: 14px 0 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mosaic__big {
    font-size: clamp(54px, 9vw, 104px);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .mosaic__copy p {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
    max-width: 380px;
  }
  .mosaic__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .mosaic__legend b {
    color: var(--accent);
    font-weight: 700;
    margin-inline-end: 4px;
  }

  /* ---- the wall: scattered at --q=0, assembled grid at --q=1 ---- */
  .mosaic__wall {
    --q: 0;
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    gap: clamp(10px, 1.6vw, 18px);
    perspective: 1100px;
  }
  .mosaic__tile {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 50px -26px rgba(0, 0, 0, 0.7);
    transform-origin: center;
    /* scattered + faded at start, snaps to grid (0,0) + crisp at end */
    transform: translate3d(
        calc(var(--dx) * (1 - var(--q))),
        calc(var(--dy) * (1 - var(--q))),
        calc(var(--depth) * -160px * (1 - var(--q)))
      )
      rotate(calc(var(--rot) * (1 - var(--q))));
    opacity: calc(0.25 + 0.75 * var(--q));
    will-change: transform, opacity;
  }
  /* RTL: mirror the horizontal scatter so depth reads symmetrically */
  [dir='rtl'] .mosaic__tile {
    transform: translate3d(
        calc(var(--dx) * -1 * (1 - var(--q))),
        calc(var(--dy) * (1 - var(--q))),
        calc(var(--depth) * -160px * (1 - var(--q)))
      )
      rotate(calc(var(--rot) * -1 * (1 - var(--q))));
  }
  .mosaic__tile :global(.asset-slot) {
    border-radius: 12px;
    width: 100%;
  }

  /* ---- fallbacks: neutralise scatter to the assembled grid end-state ---- */
  @media (prefers-reduced-motion: reduce) {
    .mosaic__tile {
      transform: none !important;
      opacity: 1 !important;
    }
  }
  @media (max-width: 820px) {
    .mosaic__wall {
      grid-template-columns: repeat(2, 1fr);
      perspective: none;
    }
    .mosaic__tile {
      transform: none !important;
      opacity: 1 !important;
      box-shadow: 0 14px 36px -24px rgba(0, 0, 0, 0.6);
    }
  }
</style>