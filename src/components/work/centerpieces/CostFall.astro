---
/** Centerpiece · meta-ads — "the cost falling".
 *  Three real cost rows ($6.25 worst → $0.84 pilot → $0.50 best) get spotlit
 *  in sequence as the proof pin scrubs, while the 3D-tilted Ads-Manager frame
 *  un-tilts toward flat. JS in lib/storyscroll.ts (data-cost / data-adshot). */
import { pick, type Lang } from '../../../i18n/utils';
import AssetSlot from '../spine/AssetSlot.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const rows = [
  { num: '$6.25', cls: 'strike', lbl: { en: 'worst ad · per call', ar: 'أسوأ إعلان · للمكالمة' } },
  { num: '$0.84', cls: '', lbl: { en: '2026 pilot · average', ar: 'تجربة ٢٠٢٦ · المتوسط' } },
  {
    num: '$0.50',
    cls: 'is-accent',
    lbl: { en: 'best campaign · Misting Fan · 106 leads', ar: 'أفضل حملة · مروحة الرذاذ · ١٠٦ عملاء' },
  },
];
---

<div class="proof__grid cf">
  <div class="cf__left reveal">
    <span class="kicker">{pick(lang, { en: 'The proof · cost per lead', ar: 'الإثبات · تكلفة العميل' })}</span>
    <div class="cf__rows">
      {
        rows.map((r) => (
          <div class="cf__row" data-cost>
            <b class={`cf__num ${r.cls}`}>{r.num}</b>
            <span class="cf__lbl">{pick(lang, r.lbl)}</span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="cf__shotwrap">
    <div class="cf__shot" data-adshot>
      <div class="cf__bar" aria-hidden="true">
        <i class="r"></i><i class="y"></i><i class="g"></i>
        <span class="addr">Ads Manager — cost breakdown</span>
      </div>
      <AssetSlot
        lang={lang}
        ratio="16/11"
        label={{ en: 'Meta Ads Manager — cost breakdown', ar: 'مدير إعلانات ميتا — تفصيل التكلفة' }}
      />
    </div>
  </div>
</div>

<style>
  .cf {
    align-items: center;
  }
  .cf__rows {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 22px;
  }
  .cf__row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    transform-origin: left center;
    flex-wrap: wrap;
  }
  [dir='rtl'] .cf__row {
    transform-origin: right center;
  }
  .cf__num {
    font-size: clamp(36px, 6vw, 66px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    direction: ltr;
    unicode-bidi: isolate;
  }
  .cf__num.strike {
    text-decoration: line-through;
    color: var(--ink-3);
  }
  .cf__num.is-accent {
    color: var(--accent);
  }
  .cf__lbl {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .cf__shotwrap {
    perspective: 1200px;
    display: flex;
    justify-content: center;
  }
  .cf__shot {
    width: 100%;
    max-width: 440px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface-raised);
    box-shadow: -24px 30px 70px -24px rgba(0, 0, 0, 0.8);
    transform: perspective(1200px) rotateX(14deg) rotateY(-18deg);
    transform-style: preserve-3d;
    will-change: transform;
  }
  [dir='rtl'] .cf__shot {
    box-shadow: 24px 30px 70px -24px rgba(0, 0, 0, 0.8);
    transform: perspective(1200px) rotateX(14deg) rotateY(18deg);
  }
  .cf__bar {
    height: 38px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    border-bottom: 1px solid var(--hair);
  }
  .cf__bar i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .cf__bar .r {
    background: #ff5f57;
  }
  .cf__bar .y {
    background: #febc2e;
  }
  .cf__bar .g {
    background: #28c840;
  }
  .cf__bar .addr {
    margin-inline-start: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  @media (max-width: 820px) {
  }
</style>
