---
/** Centerpiece · medmac-website — "the dials sweep up".
 *  A 3D-tilted browser frame of the live site un-tilts toward flat and four
 *  Lighthouse dials (Performance / Accessibility / Best Practices / SEO) sweep
 *  from 0 to their REAL scores (96–100) as the proof pin scrubs. Pure CSS off
 *  the engine's --q var (lib/storyscroll.ts sets it on the [data-proof] section);
 *  no JS here. --q=0 = tilted + empty dials, --q=1 = flat + full readable dials. */
import { pick, type Lang } from '../../../i18n/utils';
import AssetSlot from '../spine/AssetSlot.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Real Lighthouse band — never exceed the 96–100 the production runs reported.
const dials = [
  { score: 96, label: { en: 'Performance', ar: 'الأداء' } },
  { score: 100, label: { en: 'Accessibility', ar: 'الوصول' } },
  { score: 100, label: { en: 'Best Practices', ar: 'الممارسات' } },
  { score: 100, label: { en: 'SEO', ar: 'SEO' } },
];
---

<div class="proof__grid bd">
  <div class="bd__copy reveal">
    <span class="kicker">{pick(lang, { en: 'The proof · Lighthouse', ar: 'الإثبات · Lighthouse' })}</span>
    <h2>{pick(lang, { en: 'Near-perfect, on real runs.', ar: 'شبه مثالي، على قياساتٍ حقيقية.' })}</h2>
    <p>
      {
        pick(lang, {
          en: 'Four dials, measured on the production build across Arabic and English — performance never drops below 96.',
          ar: 'أربعة مؤشّرات، مُقاسة على نسخة الإنتاج عبر العربية والإنجليزية — والأداء لا يقلّ عن ٩٦.',
        })
      }
    </p>
    <a class="bd__cta" href="https://medmac-kuwait.vercel.app" target="_blank" rel="noopener noreferrer">
      <span class="bd__cta-ic" aria-hidden="true">↗</span>
      <bdi>medmac-kuwait.vercel.app</bdi>
    </a>
  </div>

  <div class="bd__framewrap">
    <div class="bd__frame" aria-hidden="true">
      <div class="bd__bar">
        <i class="r"></i><i class="y"></i><i class="g"></i>
        <span class="addr"><bdi>medmac-kuwait.vercel.app</bdi></span>
        <span class="bd__live"><span class="bd__live-dot"></span><bdi>live · Vercel</bdi></span>
      </div>
      <div class="bd__viewport">
        <AssetSlot
          lang={lang}
          ratio="16/10"
          label={{ en: 'medmac-kuwait.vercel.app — live homepage', ar: 'medmac-kuwait.vercel.app — الصفحة الرئيسية المباشرة' }}
        />
        <div class="bd__dials">
          {
            dials.map((d) => (
              <div class="bd__dial" style={`--score:${d.score}`}>
                <span class="bd__ring">
                  <b class="tnum">
                    <bdi>{d.score}</bdi>
                  </b>
                </span>
                <span class="bd__lbl">{pick(lang, d.label)}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .bd {
    align-items: center;
  }
  .bd__copy h2 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.04;
    margin: 14px 0 14px;
  }
  .bd__copy p {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
    max-width: 380px;
  }
  .bd__cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 22px;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ink);
    transition: border-color 0.25s, transform 0.25s var(--ease), background 0.25s;
  }
  .bd__cta:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }
  .bd__cta-ic {
    color: var(--accent);
    font-weight: 800;
  }

  /* ---- the 3D browser frame (un-tilts toward flat as --q rises) ---- */
  .bd__framewrap {
    perspective: 1400px;
    display: flex;
    justify-content: center;
  }
  .bd__frame {
    width: 100%;
    max-width: 460px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface-raised);
    box-shadow: -24px 30px 70px -24px rgba(0, 0, 0, 0.8);
    transform-style: preserve-3d;
    will-change: transform;
    /* --q=0 → tilted; --q=1 → flat. RTL flips the rotateY sign below. */
    transform: perspective(1400px)
      rotateX(calc((1 - var(--q, 1)) * 14deg))
      rotateY(calc((1 - var(--q, 1)) * -18deg));
  }
  [dir='rtl'] .bd__frame {
    box-shadow: 24px 30px 70px -24px rgba(0, 0, 0, 0.8);
    transform: perspective(1400px)
      rotateX(calc((1 - var(--q, 1)) * 14deg))
      rotateY(calc((1 - var(--q, 1)) * 18deg));
  }
  .bd__bar {
    height: 40px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    border-bottom: 1px solid var(--hair);
  }
  .bd__bar i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .bd__bar .r {
    background: #ff5f57;
  }
  .bd__bar .y {
    background: #febc2e;
  }
  .bd__bar .g {
    background: #28c840;
  }
  .bd__bar .addr {
    margin-inline-start: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bd__live {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .bd__live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 9px var(--accent);
    /* breathing pulse keyed off readiness, not scrub */
    animation: bd-pulse 2.4s var(--ease) infinite;
  }
  @keyframes bd-pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.7);
    }
  }

  .bd__viewport {
    position: relative;
  }
  .bd__viewport :global(.asset-slot) {
    border-radius: 0;
    border-inline: 0;
    border-top: 0;
  }

  /* ---- the four dials overlaid on the viewport ---- */
  .bd__dials {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(6px, 1.4vw, 14px);
    padding: clamp(10px, 2vw, 18px);
    background: linear-gradient(0deg, color-mix(in srgb, var(--surface-base) 92%, transparent), transparent);
  }
  .bd__dial {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .bd__ring {
    position: relative;
    width: clamp(48px, 9vw, 72px);
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    place-items: center;
    /* sweep: angle = (real score%) * current scrub progress --q */
    background: conic-gradient(
      var(--accent) calc(var(--score) * var(--q, 1) * 1%),
      color-mix(in srgb, var(--ink) 14%, transparent) 0
    );
  }
  .bd__ring::after {
    content: '';
    position: absolute;
    width: 72%;
    height: 72%;
    border-radius: 50%;
    background: var(--surface-raised);
  }
  .bd__ring b {
    position: relative;
    z-index: 1;
    font-size: clamp(15px, 2.6vw, 22px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    /* the number reads its full real value once the sweep has caught up */
    opacity: calc(0.25 + 0.75 * var(--q, 1));
  }
  .bd__lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--ink-2);
    text-align: center;
    line-height: 1.2;
  }

  /* ---- fallbacks: neutralise scrub to the readable end-state (--q=1) ---- */
  @media (prefers-reduced-motion: reduce) {
    .bd__frame {
      transform: none !important;
    }
    .bd__ring {
      background: conic-gradient(
        var(--accent) calc(var(--score) * 1%),
        color-mix(in srgb, var(--ink) 14%, transparent) 0
      ) !important;
    }
    .bd__ring b {
      opacity: 1 !important;
    }
    .bd__live-dot {
      animation: none;
    }
  }
  @media (max-width: 820px) {
    .bd__frame {
      transform: none !important;
    }
    .bd__ring {
      background: conic-gradient(
        var(--accent) calc(var(--score) * 1%),
        color-mix(in srgb, var(--ink) 14%, transparent) 0
      ) !important;
    }
    .bd__ring b {
      opacity: 1 !important;
    }
  }
</style>
