---
import Spine from './spine/Spine.astro';
import Hook from './spine/Hook.astro';
import Brief from './spine/Brief.astro';
import Build from './spine/Build.astro';
import Proof from './spine/Proof.astro';
import Honesty from './spine/Honesty.astro';
import DeviceRotate from './centerpieces/DeviceRotate.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Beat 3 · Build — "what I built / owned" items, revealed one at a time on scrub.
const buildItems = [
  {
    n: '01',
    title: { en: '15 relational tables', ar: '١٥ جدولًا علائقيًا' },
    body: {
      en: 'Every event foreign-keyed to a specific generation — with safe, non-destructive migrations on startup. Ear numbers reused after a sale or death can never blur old and new records together.',
      ar: 'كل حدثٍ مرتبطٌ بجيلٍ محدّد — مع ترحيلٍ آمنٍ غير مُتلِف عند بدء التشغيل. وأرقام الأذن المُعادة بعد بيعٍ أو نفوقٍ لا يمكن أن تُخلِط السجلات القديمة بالجديدة أبدًا.',
    },
  },
  {
    n: '02',
    title: { en: '59 assertions across 17 groups', ar: '٥٩ تحقّقًا عبر ١٧ مجموعة' },
    body: {
      en: 'An acceptance + regression suite — 0 failures — guards the identity model and every data rule.',
      ar: 'حزمة قبولٍ وانحدار — صفر إخفاقات — تحمي نموذج الهوية وكل قاعدة بيانات.',
    },
  },
  {
    n: '03',
    title: { en: 'An adversarial code review', ar: 'مراجعةٌ نقديةٌ للكود' },
    body: {
      en: 'Independent reviewers re-verified every finding — catching a vaccination-renewal data-loss bug before it shipped.',
      ar: 'مراجعون مستقلّون أعادوا التحقّق من كل ملاحظة — والتقطوا خطأ فقدان بياناتٍ في تجديد التطعيم قبل إطلاقه.',
    },
  },
  {
    n: '04',
    title: { en: 'GitHub Actions on every push', ar: 'GitHub Actions مع كل دفعة' },
    body: {
      en: 'Installs deps, runs the tests, and builds two Windows executables (Win10/11 64-bit + Win7 32-bit) — 17 successful builds — plus a macOS app.',
      ar: 'يثبّت الاعتماديات، ويشغّل الاختبارات، ويبني ملفّين تنفيذيّين لويندوز (١٠/١١ 64-bit + ٧ 32-bit) — ١٧ بناءً ناجحًا — إضافةً إلى تطبيق ماك.',
    },
  },
];

const deliveryMetrics: MetricItem[] = [
  { count: 59, label: { en: '/ 59 tests passing', ar: '/ ٥٩ اختبارًا ناجحًا' } },
  { count: 15, label: { en: 'SQLite tables', ar: 'جداول SQLite' } },
  { count: 2405, prefix: '~', label: { en: 'Lines of code', ar: 'أسطر برمجية' } },
  { count: 17, label: { en: 'Successful CI builds', ar: 'بناءات CI ناجحة' } },
];

const tools = [
  'Python',
  'Tkinter / ttk',
  'SQLite',
  'openpyxl',
  'arabic-reshaper',
  'python-bidi',
  'ctypes (HiDPI)',
  'PyInstaller',
  'GitHub Actions',
  'Git',
];

// Verbatim honesty note (the bold "Honest credit:" lead-in is moved to the beat kicker).
const note = {
  en: 'Spec-driven, AI-assisted development (Claude Code). I’m the architect, decision-maker, reviewer and operator — I set the no-mixing rule, designed the schema and the three-herd model, ran the adversarial review, and shipped the builds. Business impact (time/money saved) was never measured, so I claim only the delivery facts above.',
  ar: 'تطويرٌ مدفوعٌ بالمواصفات وبمساعدة الذكاء الاصطناعي (Claude Code). أنا المهندس وصاحب القرار والمراجع والمشغّل — وضعت قاعدة عدم الاختلاط، وصمّمت المخطّط ونموذج القطعان الثلاثة، وأجريت المراجعة النقدية، وأطلقت الإصدارات. ولم يُقَس الأثر التجاري (الوقت/المال الموفّر)، فلا أدّعي سوى حقائق التسليم أعلاه.',
};
---

<Spine lang={lang}>
  <Hook
    lang={lang}
    badge={{ en: 'Software · Desktop app', ar: 'برمجيات · تطبيق سطح مكتب' }}
    headline={{
      en: 'Software that<br><span class="gradient-text">actually ships.</span>',
      ar: 'برمجيات<br><span class="gradient-text">تُسلَّم فعلًا.</span>',
    }}
    lead={{
      en: 'An offline, bilingual desktop app for a real sheep farm — a 15-table database, a collision-proof identity model, and a decision-support engine, packaged for Windows + macOS and proven by <b>59/59 automated tests</b>.',
      ar: 'تطبيق سطح مكتب يعمل دون إنترنت وثنائي اللغة لمزرعة أغنامٍ حقيقية — قاعدة من ١٥ جدولًا، ونموذج هويةٍ مانعٌ للتصادم، ومحرّك دعمٍ للقرار، مُحزَّم لويندوز وماك ومُثبَت بـ<b>٥٩/٥٩ اختبارًا آليًا</b>.',
    }}
    heroNumber="59/59"
    heroCaption={{ en: 'automated tests<br>0 failures', ar: 'اختبارًا آليًا<br>صفر إخفاقات' }}
    ghost="59"
  />

  <Brief
    lang={lang}
    kicker={{ en: 'The hard problem', ar: 'المشكلة الصعبة' }}
    heading={{
      en: 'A data-integrity problem, disguised as a farm app.',
      ar: 'مشكلة سلامة بيانات، مُتنكّرة في هيئة تطبيق مزرعة.',
    }}
    body={{
      en: 'A vet logs daily events on an old laptop; the owner reviews what makes money. But ear numbers are reused after an animal is sold or dies — so the whole system had to guarantee old and new records could never blur together, fully offline, Arabic-first.',
      ar: 'يسجّل الطبيب الأحداث يوميًا على لابتوب قديم؛ ويراجع المالك ما الذي يُربح. لكن أرقام الأذن تُعاد بعد بيع الحيوان أو نفوقه — لذا وجب أن يضمن النظام بأكمله استحالة اختلاط السجلات القديمة بالجديدة، دون إنترنت، وبالعربية أولًا.',
    }}
    ghostWord="59/59"
  >
    <div slot="aside" style="margin-top:22px">
      <TechRow lang={lang} items={['Python', 'SQLite', 'Offline-first']} center={false} />
    </div>
    <div class="device">
      <div class="device__bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="addr">SheepFarm · offline</span>
      </div>
      <div class="device__body" style="padding:22px">
        <p class="muted" style="font-size:12px;margin-bottom:10px">
          {pick(lang, { en: 'Ear number 55 — identity timeline', ar: 'رقم الأذن ٥٥ — خط هوية' })}
        </p>
        <div class="idline">
          <span class="gen on"><bdi>55-A</bdi></span><span class="ar2">→</span>
          <span class="gen"><bdi>55-B</bdi></span><span class="ar2">→</span>
          <span class="gen ghost"><bdi>55-C</bdi></span>
        </div>
        <div class="kpis">
          <div class="kpi reveal"><b class="tnum" data-count="15">0</b><span>{pick(lang, { en: 'tables', ar: 'جداول' })}</span></div>
          <div class="kpi reveal d1"><b class="tnum" data-count="59">0</b><span>{pick(lang, { en: 'tests pass', ar: 'اختبار ناجح' })}</span></div>
          <div class="kpi reveal d2"><b class="tnum" data-count="2405" data-prefix="~">~0</b><span>{pick(lang, { en: 'lines', ar: 'سطر' })}</span></div>
        </div>
      </div>
    </div>
  </Brief>

  <Build
    lang={lang}
    kicker={{ en: 'What I built', ar: 'ما الذي بنيته' }}
    heading={{ en: 'Tested, reviewed, and CI-built.', ar: 'مُختبَر، ومُراجَع، ومبنيٌّ آليًا.' }}
    mult={2.6}
    items={buildItems}
  />

  <Proof lang={lang} center="device-rotate" mult={2.4}>
    <DeviceRotate lang={lang} />
  </Proof>

  <section class="story-section section-glow proof-numbers">
    <div class="wrap">
      <Metrics lang={lang} eyebrow={{ en: 'Delivery facts', ar: 'حقائق التسليم' }} items={deliveryMetrics} />
    </div>
  </section>

  <Honesty
    lang={lang}
    slug="sheep-app"
    kicker={{ en: 'Honest credit', ar: 'نسبٌ صادق' }}
    note={note}
  >
    <div slot="tools" style="margin-top:22px">
      <TechRow lang={lang} items={tools} center={false} />
    </div>
  </Honesty>
</Spine>

<FilmEmbed
  lang={lang}
  film="sheep.html"
  title={{ en: 'Sheep app — interactive story film', ar: 'تطبيق الأغنام — قصة تفاعلية' }}
/>

<style>
  .idline {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .idline .gen {
    font-weight: 800;
    font-size: 18px;
    padding: 8px 14px;
    border-radius: 10px;
    border: 1px solid var(--panel-brd);
    background: var(--panel);
  }
  .idline .gen.on {
    background: var(--grad);
    color: #fff;
    border-color: transparent;
  }
  .idline .gen.ghost {
    opacity: 0.4;
    border-style: dashed;
  }
  .idline .ar2 {
    color: var(--ink-3);
  }
  .kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 8px;
  }
  .kpi {
    text-align: center;
    padding: 12px;
    border: 1px solid var(--panel-brd);
    border-radius: 12px;
    background: var(--panel);
  }
  .kpi b {
    display: block;
    font-size: 24px;
    font-weight: 800;
  }
  .kpi span {
    font-size: 12px;
    color: var(--ink-2);
  }
</style>
