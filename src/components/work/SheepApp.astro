---
import StoryHero from './StoryHero.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import StatRing from '../viz/StatRing.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const tables = [
  'animals', 'rams', 'births', 'diseases', 'pregnancy', 'lactation', 'abortions',
  'vaccinations', 'deaths', 'sales', 'notes', 'lamb_moves', 'exited',
  'monthly_census', 'app_meta',
];

const feats = [
  {
    ic: '!',
    h: { en: 'Alerts that act', ar: 'تنبيهاتٌ تتصرّف' },
    p: {
      en: 'Overdue vaccinations, lambings due (150-day gestation), cull lists, and freed numbers needing assignment — each alert opens a pre-filled window so completing it clears the item.',
      ar: 'تطعيماتٌ متأخرة، وولاداتٌ مستحقّة (حملٌ ١٥٠ يومًا)، وقوائم استبعاد، وأرقامٌ مُحرَّرة تنتظر الإسناد — كل تنبيهٍ يفتح نافذةً مُعبّأة مسبقًا فيُزال البند بمجرّد إتمامه.',
    },
  },
  {
    ic: '▤',
    h: { en: 'KPIs & statistics', ar: 'مؤشرات وإحصاءات' },
    p: {
      en: 'Pregnancy, twinning, empty and lamb-mortality rates; a dashboard with month-over-month deltas and hand-drawn charts — no chart library — plus an A-vs-B period comparison.',
      ar: 'معدلات الحمل والتوائم والفراغ ونفوق الحملان؛ لوحةٌ بفوارق شهرٍ بشهر ورسومٌ مرسومة يدويًا — دون مكتبة رسوم — مع مقارنة فترتين أ مقابل ب.',
    },
  },
  {
    ic: '⤓',
    h: { en: 'Bilingual Excel export', ar: 'تصدير Excel ثنائي اللغة' },
    p: {
      en: 'Multi-sheet, colour-coded, frozen headers, native auto-filters and date-range filtering — in Arabic or English.',
      ar: 'متعدد الأوراق، مُرمَّز بالألوان، برؤوسٍ مُجمّدة وفلاتر تلقائية أصلية وتصفيةٍ بنطاق التاريخ — بالعربية أو الإنجليزية.',
    },
  },
  {
    ic: '⌗',
    h: { en: 'Three-herd ledger', ar: 'دفتر القطعان الثلاثة' },
    p: {
      en: 'Ewes, rams and lambs as a live inventory with a movement ledger, auto-age, and lamb-exit-by-sex — births in, sales/deaths/promotions out.',
      ar: 'نعاجٌ وفحولٌ وحملانٌ كمخزونٍ حيّ بدفتر حركة وعمرٍ تلقائي وخروجٍ بحسب الجنس — ولاداتٌ داخلة، وبيعٌ/نفوقٌ/ترقياتٌ خارجة.',
    },
  },
];

const steps = [
  {
    h: { en: '59 assertions across 17 groups', ar: '٥٩ تحقّقًا عبر ١٧ مجموعة' },
    p: {
      en: 'An acceptance + regression suite — 0 failures — guards the identity model and every data rule.',
      ar: 'حزمة قبولٍ وانحدار — صفر إخفاقات — تحمي نموذج الهوية وكل قاعدة بيانات.',
    },
  },
  {
    h: { en: 'An adversarial code review', ar: 'مراجعةٌ نقديةٌ للكود' },
    p: {
      en: 'Independent reviewers re-verified every finding — catching a vaccination-renewal data-loss bug before it shipped.',
      ar: 'مراجعون مستقلّون أعادوا التحقّق من كل ملاحظة — والتقطوا خطأ فقدان بياناتٍ في تجديد التطعيم قبل إطلاقه.',
    },
  },
  {
    h: { en: 'GitHub Actions on every push', ar: 'GitHub Actions مع كل دفعة' },
    p: {
      en: 'Installs deps, runs the tests, and builds two Windows executables (Win10/11 64-bit + Win7 32-bit) — 17 successful builds — plus a macOS app.',
      ar: 'يثبّت الاعتماديات، ويشغّل الاختبارات، ويبني ملفّين تنفيذيّين لويندوز (١٠/١١ 64-bit + ٧ 32-bit) — ١٧ بناءً ناجحًا — إضافةً إلى تطبيق ماك.',
    },
  },
];

const deliveryMetrics: MetricItem[] = [
  { count: 59, label: { en: '/ 59 tests passing', ar: '/ ٥٩ اختبارًا ناجحًا' } },
  { count: 15, label: { en: 'SQLite tables', ar: 'جداول SQLite' } },
  { count: 2405, prefix: '~', label: { en: 'Lines of code', ar: 'أسطر برمجية' } },
  { count: 17, label: { en: 'Successful CI builds', ar: 'بناءات CI ناجحة' } },
];

const honest = {
  en: '<b>Honest credit:</b> Spec-driven, AI-assisted development (Claude Code). I’m the architect, decision-maker, reviewer and operator — I set the no-mixing rule, designed the schema and the three-herd model, ran the adversarial review, and shipped the builds. Business impact (time/money saved) was never measured, so I claim only the delivery facts above.',
  ar: '<b>نسبٌ صادق:</b> تطويرٌ مدفوعٌ بالمواصفات وبمساعدة الذكاء الاصطناعي (Claude Code). أنا المهندس وصاحب القرار والمراجع والمشغّل — وضعت قاعدة عدم الاختلاط، وصمّمت المخطّط ونموذج القطعان الثلاثة، وأجريت المراجعة النقدية، وأطلقت الإصدارات. ولم يُقَس الأثر التجاري (الوقت/المال الموفّر)، فلا أدّعي سوى حقائق التسليم أعلاه.',
};
---

<StoryHero
  lang={lang}
  badge={{ en: 'Software · Desktop app', ar: 'برمجيات · تطبيق سطح مكتب' }}
  headline={{
    en: 'Software that<br><span class="gradient-text">actually ships.</span>',
    ar: 'برمجيات<br><span class="gradient-text">تُسلَّم فعلًا.</span>',
  }}
  lead={{
    en: 'An offline, bilingual desktop app for a real sheep farm — a 15-table database, a collision-proof identity model, and a decision-support engine, packaged for Windows + macOS and proven by <b style="color:var(--ink)">59/59 automated tests</b>.',
    ar: 'تطبيق سطح مكتب يعمل دون إنترنت وثنائي اللغة لمزرعة أغنامٍ حقيقية — قاعدة من ١٥ جدولًا، ونموذج هويةٍ مانعٌ للتصادم، ومحرّك دعمٍ للقرار، مُحزَّم لويندوز وماك ومُثبَت بـ<b style="color:var(--ink)">٥٩/٥٩ اختبارًا آليًا</b>.',
  }}
/>

<FilmEmbed
  lang={lang}
  film="sheep.html"
  title={{ en: 'Sheep app — interactive story film', ar: 'تطبيق الأغنام — قصة تفاعلية' }}
/>

<!-- THE HARD PROBLEM -->
<section class="story-section">
  <div class="wrap two-col">
    <div class="stack">
      <p class="kicker reveal">{pick(lang, { en: 'The hard problem', ar: 'المشكلة الصعبة' })}</p>
      <h2 class="h-lg reveal d1">
        {pick(lang, {
          en: 'A data-integrity problem, disguised as a farm app.',
          ar: 'مشكلة سلامة بيانات، مُتنكّرة في هيئة تطبيق مزرعة.',
        })}
      </h2>
      <p class="lead reveal d2">
        {pick(lang, {
          en: 'A vet logs daily events on an old laptop; the owner reviews what makes money. But ear numbers are reused after an animal is sold or dies — so the whole system had to guarantee old and new records could never blur together, fully offline, Arabic-first.',
          ar: 'يسجّل الطبيب الأحداث يوميًا على لابتوب قديم؛ ويراجع المالك ما الذي يُربح. لكن أرقام الأذن تُعاد بعد بيع الحيوان أو نفوقه — لذا وجب أن يضمن النظام بأكمله استحالة اختلاط السجلات القديمة بالجديدة، دون إنترنت، وبالعربية أولًا.',
        })}
      </p>
    </div>
    <div class="reveal d1">
      <div class="device">
        <div class="device__bar">
          <span class="d r"></span><span class="d y"></span><span class="d g"></span>
          <span class="addr">SheepFarm · offline</span>
        </div>
        <div class="device__body" style="padding:22px">
          <p class="muted" style="font-size:12px;margin-bottom:10px">
            {pick(lang, { en: 'Ear number 55 — identity timeline', ar: 'رقم الأذن ٥٥ — خط هوية' })}
          </p>
          <div class="idline">
            <span class="gen on">55-A</span><span class="ar2">→</span>
            <span class="gen">55-B</span><span class="ar2">→</span>
            <span class="gen ghost">55-C</span>
          </div>
          <div class="kpis">
            <div class="kpi reveal"><b class="tnum" data-count="15">0</b><span>{pick(lang, { en: 'tables', ar: 'جداول' })}</span></div>
            <div class="kpi reveal d1"><b class="tnum" data-count="59">0</b><span>{pick(lang, { en: 'tests pass', ar: 'اختبار ناجح' })}</span></div>
            <div class="kpi reveal d2"><b class="tnum" data-count="2405" data-prefix="~">~0</b><span>{pick(lang, { en: 'lines', ar: 'سطر' })}</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- THE DATA MODEL -->
<section class="story-section">
  <div class="wrap">
    <div class="center stack" style="max-width:740px;margin-inline:auto">
      <p class="kicker reveal">{pick(lang, { en: 'The data model', ar: 'نموذج البيانات' })}</p>
      <h2 class="h-xl reveal d1">{pick(lang, { en: '15 relational tables.', ar: '١٥ جدولًا علائقيًا.' })}</h2>
      <p class="lead reveal d2">
        {pick(lang, {
          en: 'Every event foreign-keyed to a specific generation — with safe, non-destructive migrations on startup.',
          ar: 'كل حدثٍ مرتبطٌ بجيلٍ محدّد — مع ترحيلٍ آمنٍ غير مُتلِف عند بدء التشغيل.',
        })}
      </p>
    </div>
    <div class="tbls big reveal" style="margin:40px auto 0;max-width:860px">
      {tables.map((tname) => <span>{tname}</span>)}
    </div>
  </div>
</section>

<!-- DECISION-SUPPORT -->
<section class="story-section">
  <div class="wrap">
    <div class="center stack" style="max-width:720px;margin-inline:auto">
      <p class="kicker reveal">{pick(lang, { en: 'The decision-support engine', ar: 'محرّك دعم القرار' })}</p>
      <h2 class="h-xl reveal d1">{pick(lang, { en: 'Raw events become decisions.', ar: 'أحداثٌ خام تتحوّل إلى قرارات.' })}</h2>
    </div>
    <div class="feat-list" style="max-width:880px;margin:46px auto 0">
      {
        feats.map((f, i) => (
          <div class={`feat reveal${i ? ` d${i}` : ''}`}>
            <div class="ic" aria-hidden="true">{f.ic}</div>
            <div>
              <h4>{f.h[lang]}</h4>
              <p>{f.p[lang]}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- BUILT TO LAST -->
<section class="story-section">
  <div class="wrap">
    <div class="center stack" style="max-width:720px;margin-inline:auto">
      <p class="kicker reveal">{pick(lang, { en: 'Built to last', ar: 'مبنيٌّ ليدوم' })}</p>
      <h2 class="h-xl reveal d1">{pick(lang, { en: 'Tested, reviewed, and CI-built.', ar: 'مُختبَر، ومُراجَع، ومبنيٌّ آليًا.' })}</h2>
    </div>
    <div class="steps" style="max-width:840px;margin:46px auto 0">
      {
        steps.map((s, i) => (
          <div class={`step reveal${i ? ` d${i}` : ''}`}>
            <div class="step__n"></div>
            <div>
              <h4>{s.h[lang]}</h4>
              <p>{s.p[lang]}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- DELIVERY FACTS -->
<section class="story-section section-glow">
  <div class="wrap">
    <div class="center stack" style="max-width:560px;margin-inline:auto;margin-bottom:44px">
      <p class="kicker reveal">{pick(lang, { en: 'Delivery facts', ar: 'حقائق التسليم' })}</p>
      <StatRing
        lang={lang}
        pct={100}
        display="59/59"
        label={{ en: 'automated tests passing', ar: 'اختبارًا آليًا ناجحًا' }}
        sub={{ en: '0 failures · 17 assertion groups', ar: 'صفر إخفاقات · ١٧ مجموعة تحقّق' }}
      />
    </div>
    <Metrics lang={lang} items={deliveryMetrics} />
    <div class="note reveal" style="margin-top:30px" set:html={honest[lang]}></div>
  </div>
</section>

<!-- TECH -->
<section class="story-section">
  <div class="wrap center stack" style="max-width:820px;margin-inline:auto">
    <p class="kicker reveal">{pick(lang, { en: 'Tech', ar: 'التقنيات' })}</p>
    <TechRow
      lang={lang}
      items={['Python', 'Tkinter / ttk', 'SQLite', 'openpyxl', 'arabic-reshaper', 'python-bidi', 'ctypes (HiDPI)', 'PyInstaller', 'GitHub Actions', 'Git']}
    />
  </div>
</section>

<style>
  .idline{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:18px}
  .idline .gen{font-weight:800;font-size:18px;padding:8px 14px;border-radius:10px;border:1px solid var(--panel-brd);background:var(--panel)}
  .idline .gen.on{background:var(--grad);color:#fff;border-color:transparent}
  .idline .gen.ghost{opacity:.4;border-style:dashed}
  .idline .ar2{color:var(--ink-3)}
  .kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:8px}
  .kpi{text-align:center;padding:12px;border:1px solid var(--panel-brd);border-radius:12px;background:var(--panel)}
  .kpi b{display:block;font-size:24px;font-weight:800}
  .kpi span{font-size:12px;color:var(--ink-2)}
  .tbls{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;max-width:560px;margin-inline:auto}
  .tbls span{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12.5px;color:var(--ink);background:color-mix(in srgb,var(--accent) 12%,transparent);border:1px solid var(--panel-brd);border-radius:8px;padding:6px 11px}
  .tbls.big span{font-size:14px;padding:9px 15px}
</style>
