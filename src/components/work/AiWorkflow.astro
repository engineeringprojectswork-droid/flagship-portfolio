---
import StoryHero from './StoryHero.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const funnel = [
  {
    w: '100%',
    d: 0,
    label: { en: 'RFQs consolidated', ar: 'طلبات مُجمَّعة' },
    count: 23,
  },
  {
    w: '100%',
    d: 1,
    label: { en: 'Reply drafts written', ar: 'مسوّدات ردود' },
    count: 23,
  },
  {
    w: '24%',
    d: 2,
    label: { en: 'Live tenders recovered', ar: 'مناقصات حيّة مُستعادة' },
    count: 4,
  },
];

const droveMetrics: MetricItem[] = [
  { count: 23, label: { en: 'RFQs consolidated', ar: 'طلبات عروض مُجمَّعة' } },
  { count: 4, label: { en: 'Live tenders recovered', ar: 'مناقصات حيّة مُستعادة' } },
  { count: 3, label: { en: 'Automations on schedule', ar: 'أتمتةٌ مجدولة' } },
  { count: 23, prefix: '~', label: { en: 'Website commits shipped', ar: 'دفعات موقع مُسلَّمة' } },
];

const honest = {
  en: '<b>Honest credit:</b> The AI tools execute under my direction — I designed the model, wrote the briefs, set the no-fabrication rules, and made every decision. Hours or money saved were never measured, so I don’t claim them; the 4 recovered tenders are the concrete, sourced win.',
  ar: '<b>نسبٌ صادق:</b> أدوات الذكاء تُنفّذ تحت إدارتي — صمّمت النموذج، وكتبت المهام، ووضعت قواعد "لا اختلاق"، واتخذت كل قرار. ولم يُقَس الوقت أو المال الموفّر، فلا أدّعيه؛ والمناقصات الأربع المُستعادة هي المكسب الملموس والموثّق.',
};

const tools = [
  'Cowork',
  'Claude Code',
  'Claude Design',
  'Scheduled tasks',
  'Python · openpyxl',
  'Astro · Vercel',
  'Gmail · Drive',
  'WhatsApp Web',
];
---

<StoryHero
  lang={lang}
  badge={{ en: 'AI Operating Model', ar: 'نموذج تشغيل بالذكاء الاصطناعي' }}
  headline={{
    en: 'One person.<br><span class="gradient-text">Three AI tools.</span>',
    ar: 'شخصٌ واحد.<br><span class="gradient-text">ثلاث أدوات ذكاء.</span>',
  }}
  headlineStyle="font-size:clamp(38px,7.5vw,104px)"
  lead={{
    en: 'I direct three AI tools as one system — and it ships real work. The same model recovered <b style="color:var(--ink)">4 live tenders</b> a manual list had missed. (It’s how this very site is being built.)',
    ar: 'أُوجّه ثلاث أدوات ذكاءٍ كنظامٍ واحد — وهو يُنجز عملًا حقيقيًا. وقد استعاد النموذج نفسه <b style="color:var(--ink)">٤ مناقصاتٍ حيّة</b> أغفلتها قائمةٌ يدوية. (وهكذا يُبنى هذا الموقع ذاته.)',
  }}
/>

<FilmEmbed
  lang={lang}
  film="ai-workflow.html"
  title={{ en: 'Interactive story film', ar: 'Interactive story film' }}
/>

<!-- THE OPERATING MODEL -->
<section class="story-section">
  <div class="wrap">
    <div class="center stack" style="max-width:720px;margin-inline:auto">
      <p class="kicker reveal">{pick(lang, { en: 'The operating model', ar: 'نموذج التشغيل' })}</p>
      <h2 class="h-xl reveal d1">{pick(lang, { en: 'I’m the controller.', ar: 'أنا المُتحكِّم.' })}</h2>
    </div>
    <div class="orchestra reveal d1">
      <div class="node ctrl">
        <b>{pick(lang, { en: 'Me + Cowork', ar: 'أنا + Cowork' })}</b>
        <span>{pick(lang, { en: 'Controller · memory · briefs · verify', ar: 'تحكّم · ذاكرة · مهام · تحقّق' })}</span>
      </div>
      <div class="branch"><span class="arm a1"></span><span class="arm a2"></span></div>
      <div class="leaves">
        <div class="node">
          <b>Claude Design</b>
          <span>{pick(lang, { en: 'The look — only', ar: 'الشكل — فقط' })}</span>
        </div>
        <div class="node">
          <b>Claude Code</b>
          <span>{pick(lang, { en: 'Build · git · deploy', ar: 'بناء · git · نشر' })}</span>
        </div>
      </div>
    </div>
    <p class="muted center" style="font-size:13px;margin-top:18px">
      {pick(lang, {
        en: 'Every handoff is a labelled, ready-to-paste brief — so work is never redone and context is never lost.',
        ar: 'كل تسليمٍ مهمةٌ مُعنونة جاهزة للّصق — فلا يُعاد العمل ولا يُفقد السياق.',
      })}
    </p>
  </div>
</section>

<!-- THE WIN IT CAUGHT -->
<section class="story-section">
  <div class="wrap two-col">
    <div class="stack">
      <p class="kicker reveal">{pick(lang, { en: 'The win it caught', ar: 'المكسب الذي التقطه' })}</p>
      <h2 class="h-lg reveal d1">
        {pick(lang, {
          en: '23 tenders found. 4 of them, nearly lost.',
          ar: '٢٣ مناقصة. ٤ منها كادت تضيع.',
        })}
      </h2>
      <p class="lead reveal d2">
        {pick(lang, {
          en: 'I pointed the system at 6 months of email, separated genuine RFQs from supplier noise, ranked them by deadline, and drafted a reply for each — surfacing 4 live tenders the manual list had dropped.',
          ar: 'وجّهت النظام إلى ٦ أشهرٍ من البريد، وفصلت طلبات العروض الحقيقية عن ضجيج المورّدين، ورتّبتها حسب الموعد النهائي، وصغت ردًّا لكلٍّ منها — كاشفًا ٤ مناقصاتٍ حيّة أسقطتها القائمة اليدوية.',
        })}
      </p>
    </div>
    <div class="reveal d1">
      <div class="device">
        <div class="device__bar">
          <span class="d r"></span><span class="d y"></span><span class="d g"></span>
          <span class="addr">RFQ pipeline</span>
        </div>
        <div class="device__body" style="padding:26px">
          <div class="funnel">
            {
              funnel.map((f) => (
                <div class={`fbar reveal${f.d ? ` d${f.d}` : ''}`} style={`--w:${f.w}`}>
                  <span>{pick(lang, f.label)}</span>
                  <b class="tnum" data-count={f.count} data-duration="1400">
                    0
                  </b>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT IT DROVE -->
<section class="story-section section-glow">
  <div class="wrap">
    <Metrics
      lang={lang}
      eyebrow={{ en: 'What it drove', ar: 'ما الذي أنجزه' }}
      items={droveMetrics}
    />
    <div class="note reveal" style="margin-top:30px" set:html={honest[lang]}></div>
  </div>
</section>

<!-- TOOLS ORCHESTRATED -->
<section class="story-section">
  <div class="wrap center stack" style="max-width:760px;margin-inline:auto">
    <p class="kicker reveal">{pick(lang, { en: 'Tools orchestrated', ar: 'الأدوات المُنسَّقة' })}</p>
    <TechRow lang={lang} items={tools} center={true} />
  </div>
</section>

<style>
  .funnel {
    display: grid;
    gap: 12px;
  }
  .fbar {
    position: relative;
    border-radius: 12px;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border: 1px solid var(--panel-brd);
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
  }
  .fbar::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--grad);
    opacity: 0.18;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.2s var(--ease);
  }
  [dir='rtl'] .fbar::before {
    transform-origin: right;
  }
  .fbar.in::before {
    transform: scaleX(1);
  }
  .fbar b {
    font-size: 19px;
    font-weight: 800;
    position: relative;
  }
  .fbar span {
    position: relative;
    color: var(--ink-2);
    font-weight: 600;
    font-size: 14px;
  }
  .orchestra {
    max-width: 760px;
    margin: 44px auto 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .orchestra .node {
    width: 100%;
    max-width: 360px;
    text-align: center;
    padding: 20px;
    border: 1px solid var(--panel-brd);
    border-radius: 16px;
    background: var(--panel);
  }
  .orchestra .node b {
    display: block;
    font-size: 19px;
    font-weight: 800;
  }
  .orchestra .node span {
    font-size: 13px;
    color: var(--ink-2);
  }
  .orchestra .node.ctrl {
    border-color: transparent;
    background: var(--grad);
    color: #fff;
  }
  .orchestra .node.ctrl span {
    color: rgba(255, 255, 255, 0.85);
  }
  .branch {
    height: 42px;
    width: 2px;
    background: var(--panel-brd);
    position: relative;
  }
  .branch .arm {
    position: absolute;
    top: 50%;
    height: 2px;
    width: 130px;
    background: var(--panel-brd);
  }
  .branch .a1 {
    right: 0;
    transform-origin: left;
  }
  .branch .a2 {
    left: 0;
    transform-origin: right;
  }
  .leaves {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    width: 100%;
    max-width: 560px;
    margin-top: 0;
  }
  @media (max-width: 560px) {
    .leaves {
      grid-template-columns: 1fr;
    }
  }
</style>
