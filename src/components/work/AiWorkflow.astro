---
import Spine from './spine/Spine.astro';
import Hook from './spine/Hook.astro';
import Brief from './spine/Brief.astro';
import Build from './spine/Build.astro';
import Proof from './spine/Proof.astro';
import Honesty from './spine/Honesty.astro';
import Orbit from './centerpieces/Orbit.astro';
import FilmEmbed from './FilmEmbed.astro';
import Metrics, { type MetricItem } from '../Metrics.astro';
import TechRow from '../TechRow.astro';
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Brief artifact — the RFQ pipeline funnel (verbatim from the current story).
const funnel = [
  { w: '100%', d: 0, label: { en: 'RFQs consolidated', ar: 'طلبات مُجمَّعة' }, count: 23 },
  { w: '100%', d: 1, label: { en: 'Reply drafts written', ar: 'مسوّدات ردود' }, count: 23 },
  { w: '24%', d: 2, label: { en: 'Live tenders recovered', ar: 'مناقصات حيّة مُستعادة' }, count: 4 },
];

// Beat 3 · Build — the operating model + the win, broken into scrub items.
const buildItems = [
  {
    n: '01',
    title: { en: 'I’m the controller', ar: 'أنا المُتحكِّم' },
    body: {
      en: 'Me + Cowork hold the memory, write the briefs, and verify — every handoff is a labelled, ready-to-paste brief, so work is never redone and context is never lost.',
      ar: 'أنا + Cowork نحفظ الذاكرة، ونكتب المهام، ونتحقّق — وكل تسليمٍ مهمةٌ مُعنونة جاهزة للّصق، فلا يُعاد العمل ولا يُفقد السياق.',
    },
  },
  {
    n: '02',
    title: { en: 'Claude Design — the look', ar: 'Claude Design — الشكل' },
    body: {
      en: 'One AI tool owns the look, only. Direction in, design out.',
      ar: 'أداة ذكاءٍ واحدة تتولّى الشكل، فقط. توجيهٌ يدخل، وتصميمٌ يخرج.',
    },
  },
  {
    n: '03',
    title: { en: 'Claude Code — build · git · deploy', ar: 'Claude Code — بناء · git · نشر' },
    body: {
      en: 'A second AI tool turns the brief into shipped code — build, git, deploy. (It’s how this very site is being built.)',
      ar: 'أداة ذكاءٍ ثانية تُحوّل المهمة إلى كودٍ مُسلَّم — بناء وgit ونشر. (وهكذا يُبنى هذا الموقع ذاته.)',
    },
  },
  {
    n: '04',
    title: { en: 'The win it caught', ar: 'المكسب الذي التقطه' },
    body: {
      en: 'I pointed the system at 6 months of email, separated genuine RFQs from supplier noise, ranked them by deadline, and drafted a reply for each — surfacing 4 live tenders the manual list had dropped.',
      ar: 'وجّهت النظام إلى ٦ أشهرٍ من البريد، وفصلت طلبات العروض الحقيقية عن ضجيج المورّدين، ورتّبتها حسب الموعد النهائي، وصغت ردًّا لكلٍّ منها — كاشفًا ٤ مناقصاتٍ حيّة أسقطتها القائمة اليدوية.',
    },
  },
];

// Numbers grid — verbatim from the current story ("What it drove").
const droveMetrics: MetricItem[] = [
  { count: 23, label: { en: 'RFQs consolidated', ar: 'طلبات عروض مُجمَّعة' } },
  { count: 4, label: { en: 'Live tenders recovered', ar: 'مناقصات حيّة مُستعادة' } },
  { count: 3, label: { en: 'Automations on schedule', ar: 'أتمتةٌ مجدولة' } },
  { count: 23, prefix: '~', label: { en: 'Website commits shipped', ar: 'دفعات موقع مُسلَّمة' } },
];

const tools = [
  'Cowork',
  'Claude Code',
  'Claude Design',
  'Scheduled tasks',
  'Python · openpyxl',
  'Astro · Vercel',
  'Gmail · Drive',
  'WhatsApp Web',
];

// Verbatim honesty note (bold lead-in moved into the Honesty kicker).
const note = {
  en: 'The AI tools execute under my direction — I designed the model, wrote the briefs, set the no-fabrication rules, and made every decision. Hours or money saved were never measured, so I don’t claim them; the 4 recovered tenders are the concrete, sourced win.',
  ar: 'أدوات الذكاء تُنفّذ تحت إدارتي — صمّمت النموذج، وكتبت المهام، ووضعت قواعد "لا اختلاق"، واتخذت كل قرار. ولم يُقَس الوقت أو المال الموفّر، فلا أدّعيه؛ والمناقصات الأربع المُستعادة هي المكسب الملموس والموثّق.',
};
---

<Spine lang={lang}>
  <Hook
    lang={lang}
    badge={{ en: 'AI Operating Model', ar: 'نموذج تشغيل بالذكاء الاصطناعي' }}
    headline={{
      en: 'One person.<br><span class="gradient-text">Three AI tools.</span>',
      ar: 'شخصٌ واحد.<br><span class="gradient-text">ثلاث أدوات ذكاء.</span>',
    }}
    lead={{
      en: 'I direct three AI tools as one system — and it ships real work. The same model recovered <b>4 live tenders</b> a manual list had missed. (It’s how this very site is being built.)',
      ar: 'أُوجّه ثلاث أدوات ذكاءٍ كنظامٍ واحد — وهو يُنجز عملًا حقيقيًا. وقد استعاد النموذج نفسه <b>٤ مناقصاتٍ حيّة</b> أغفلتها قائمةٌ يدوية. (وهكذا يُبنى هذا الموقع ذاته.)',
    }}
    heroNumber="23 tenders"
    heroCaption={{ en: 'found · 4 of them<br>nearly lost', ar: 'مُكتشَفة · ٤ منها<br>كادت تضيع' }}
    ghost="AI"
  />

  <Brief
    lang={lang}
    kicker={{ en: 'The win it caught', ar: 'المكسب الذي التقطه' }}
    heading={{ en: '23 tenders found. 4 of them, nearly lost.', ar: '٢٣ مناقصة. ٤ منها كادت تضيع.' }}
    body={{
      en: 'I pointed the system at 6 months of email, separated genuine RFQs from supplier noise, ranked them by deadline, and drafted a reply for each — surfacing 4 live tenders the manual list had dropped.',
      ar: 'وجّهت النظام إلى ٦ أشهرٍ من البريد، وفصلت طلبات العروض الحقيقية عن ضجيج المورّدين، ورتّبتها حسب الموعد النهائي، وصغت ردًّا لكلٍّ منها — كاشفًا ٤ مناقصاتٍ حيّة أسقطتها القائمة اليدوية.',
    }}
    ghostWord="RFQ"
  >
    <div slot="aside" style="margin-top:22px">
      <TechRow lang={lang} items={['Cowork', 'Claude Design', 'Claude Code']} center={false} />
    </div>
    <div class="device">
      <div class="device__bar">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="addr">RFQ pipeline</span>
      </div>
      <div class="device__body" style="padding:26px">
        <div class="funnel">
          {
            funnel.map((f) => (
              <div class={`fbar reveal${f.d ? ` d${f.d}` : ''}`} style={`--w:${f.w}`}>
                <span>{pick(lang, f.label)}</span>
                <b class="tnum" data-count={f.count} data-duration="1400">
                  0
                </b>
              </div>
            ))
          }
        </div>
        <p class="muted" style="font-size:12.5px;margin-top:16px">
          {
            pick(lang, {
              en: '6 months of email · genuine RFQs ranked by deadline',
              ar: '٦ أشهرٍ من البريد · طلبات حقيقية مُرتَّبة حسب الموعد',
            })
          }
        </p>
      </div>
    </div>
  </Brief>

  <Build
    lang={lang}
    kicker={{ en: 'The operating model', ar: 'نموذج التشغيل' }}
    heading={{ en: 'I’m the controller.', ar: 'أنا المُتحكِّم.' }}
    intro={{
      en: 'Three AI tools, one system — directed end-to-end through labelled briefs.',
      ar: 'ثلاث أدوات ذكاء، نظامٌ واحد — مُوجَّهٌ من الألف إلى الياء عبر مهامٍ مُعنونة.',
    }}
    mult={2.6}
    items={buildItems}
  />

  <Proof lang={lang} center="orbit" mult={2.4}>
    <Orbit lang={lang} />
  </Proof>

  <section class="story-section section-glow proof-numbers">
    <div class="wrap">
      <Metrics lang={lang} eyebrow={{ en: 'What it drove', ar: 'ما الذي أنجزه' }} items={droveMetrics} />
    </div>
  </section>

  <Honesty
    lang={lang}
    slug="ai-workflow"
    kicker={{ en: 'Honest credit', ar: 'نسبٌ صادق' }}
    note={note}
  >
    <div slot="tools" style="margin-top:22px">
      <TechRow lang={lang} items={tools} center={false} />
    </div>
  </Honesty>
</Spine>

<FilmEmbed lang={lang} film="ai-workflow.html" title={{ en: 'AI workflow — interactive story film', ar: 'فيلم القصة التفاعلي — منظومة الذكاء' }} />

<style>
  .funnel {
    display: grid;
    gap: 12px;
  }
  .fbar {
    position: relative;
    border-radius: 12px;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border: 1px solid var(--panel-brd);
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
  }
  .fbar::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--grad);
    opacity: 0.18;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.2s var(--ease);
  }
  [dir='rtl'] .fbar::before {
    transform-origin: right;
  }
  .fbar.in::before {
    transform: scaleX(1);
  }
  .fbar b {
    font-size: 19px;
    font-weight: 800;
    position: relative;
  }
  .fbar span {
    position: relative;
    color: var(--ink-2);
    font-weight: 600;
    font-size: 14px;
  }
</style>
