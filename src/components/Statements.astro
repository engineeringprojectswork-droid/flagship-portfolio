---
import { pick, type Lang } from '../i18n/utils';
import Biome from './Biome.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// One space biome per statement line (same universe, a new region each time).
const biomes = ['nebula', 'warp', 'grid', 'aurora', 'singularity'] as const;
// Per-line accent tint so each scene is its own colour (independent of page accent).
const tints = ['#2997ff', '#ff5e8a', '#30d158', '#bf5af2', '#ff9f0a'];

// Each line earns its screen with a large low-opacity ghost metric + a one-line
// stat behind it. Every number traces to the real work (profile.ts / the stories).
type Line = { en: string; ar: string; grad?: boolean; ghost: string; stat: { en: string; ar: string } };
const lines: Line[] = [
  {
    en: 'I run the ads.',
    ar: 'أُدير الإعلانات.',
    ghost: '206',
    stat: { en: '206 WhatsApp leads · $0.84 each', ar: '٢٠٦ عميل واتساب · ٠٫٨٤$ للعميل' },
  },
  {
    en: 'I grow the audience.',
    ar: 'أُنمّي الجمهور.',
    ghost: '1M',
    stat: { en: '9.2K → 1M+ followers · 2021–2025', ar: '٩٫٢ ألف ← مليون+ متابع · ٢٠٢١–٢٠٢٥' },
  },
  {
    en: 'I build the systems.',
    ar: 'أبني الأنظمة.',
    ghost: '12',
    stat: { en: 'a 12-tab CRM · a 15-table desktop app', ar: 'نظام عملاء ١٢ جدولًا · تطبيق ١٥ جدولًا' },
  },
  {
    en: 'I automate the rest with AI.',
    ar: 'وأُشغّل الباقي آليًا بالذكاء الاصطناعي.',
    ghost: '142',
    stat: { en: '142 résumés · 7 scripts · 3 scheduled jobs', ar: '١٤٢ سيرة ذاتية · ٧ نصوص برمجية · ٣ مهام مجدولة' },
  },
  {
    en: 'So a business gets a full team’s output —<br>from a single hire.',
    ar: 'فيحصل العمل على إنتاج فريقٍ كامل —<br>بموظَّفٍ واحد.',
    grad: true,
    ghost: '1',
    stat: { en: 'one person · four production systems shipped', ar: 'شخصٌ واحد · أربعة أنظمة إنتاجية' },
  },
];
---

<section class="statements" aria-label={lang === 'ar' ? 'ما الذي أفعله' : 'What I do'}>
  {
    lines.map((l, i) => (
      <div class="statement" data-ghost={l.ghost}>
        <Biome kind={biomes[i % biomes.length]} tint={tints[i % tints.length]} />
        <div class="statement__inner">
          <p class={`reveal${l.grad ? ' gradient-text shimmer' : ''}`} set:html={l[lang]} />
          <span class="statement__stat reveal d2">{pick(lang, l.stat)}</span>
        </div>
      </div>
    ))
  }
</section>
