---
import { pick, type Lang } from '../i18n/utils';
import { profile } from '../data/profile';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const ar = lang === 'ar';

// Converging-light hero (Claude Design pack #2). SSR-bilingual: the correct
// language is rendered server-side (no flash); the canvas + reveal run client-side.
const eyebrow = `${pick(lang, profile.name)} · ${pick(lang, profile.location)}`;
const l1 = ar ? 'فريق تسويق كامل.' : 'A whole marketing team.';
const l2 = ar ? 'في شخص واحد.' : 'In one person.';
const lead = ar
  ? 'أُدير الحملات الإعلانية، وأُنتج المحتوى، وأبني نظام إدارة العملاء، وأُشغّل بقية العمل آليًا بالذكاء الاصطناعي — وأُطلق التطبيقات بنفسي أيضًا.'
  : 'I run the ads, produce the content, build the CRM, and automate the rest with AI — and I ship the software too.';
const cta1 = ar ? 'شاهد الأعمال' : 'See the work';
const cta2 = ar ? 'تواصل معي' : 'Get in touch';
const scroll = ar ? 'مرّر للأسفل' : 'Scroll';
const arrow = ar ? '←' : '→';
---

<section class:list={['hh', { 'is-ar': ar }]} id="intro" aria-label={`${pick(lang, profile.name)} — ${l1} ${l2}`}>
  <div class="hh-stars" aria-hidden="true"></div>
  <div class="hh-aurora a" aria-hidden="true"></div>
  <div class="hh-aurora b" aria-hidden="true"></div>
  <div class="hh-aurora c" aria-hidden="true"></div>
  <div class="hh-corefb" aria-hidden="true"></div>
  <canvas id="heroFx" class="hh-fx" aria-hidden="true"></canvas>
  <div class="hh-scrim" aria-hidden="true"></div>

  <div class="hh-wrap">
    <p class="hh-eyebrow hh-reveal">{eyebrow}</p>
    <h1 class="hh-h">
      <span class="hh-l1 hh-reveal">{l1}</span>
      <span class="hh-l2 hh-reveal">{l2}</span>
    </h1>
    <p class="hh-lead hh-reveal">{lead}</p>
    <div class="hh-cta hh-reveal">
      <a class="hh-btn hh-btn--primary" href="#work">{cta1} <span class="hh-arr" aria-hidden="true">{arrow}</span></a>
      <a class="hh-btn hh-btn--ghost" href="#contact">{cta2}</a>
    </div>
  </div>

  <div class="hh-scroll" aria-hidden="true">
    <span>{scroll}</span>
    <svg viewBox="0 0 16 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="1" width="14" height="20" rx="7"></rect><path d="M8 5v4"></path><path d="M5 14l3 3 3-3"></path></svg>
  </div>
</section>

<style>
  .hh {
    --pink: #ff5e8a; --violet: #a259ff; --blue: #2997ff; --cyan: #64d2ff; --nav: 64px;
    position: relative; width: 100%; height: 100svh; min-height: 560px; overflow: hidden;
    background: radial-gradient(140% 120% at 50% 42%, #0d0e1c 0%, #08080f 50%, #050509 100%);
  }
  .hh.is-ar { font-family: var(--font-ar-display, "SF Arabic", "Segoe UI", "Noto Sans Arabic", Tahoma, sans-serif); }

  .hh-stars {
    position: absolute; inset: -10%; z-index: 0; pointer-events: none;
    background-image:
      radial-gradient(1.5px 1.5px at 12% 18%, rgba(255,255,255,.7), transparent 60%),
      radial-gradient(1.2px 1.2px at 82% 12%, rgba(180,210,255,.6), transparent 60%),
      radial-gradient(1px 1px at 28% 72%, rgba(255,255,255,.5), transparent 60%),
      radial-gradient(1.6px 1.6px at 68% 78%, rgba(200,170,255,.5), transparent 60%),
      radial-gradient(1px 1px at 90% 56%, rgba(255,255,255,.45), transparent 60%),
      radial-gradient(1.3px 1.3px at 18% 88%, rgba(180,210,255,.45), transparent 60%),
      radial-gradient(1px 1px at 46% 30%, rgba(255,255,255,.4), transparent 60%),
      radial-gradient(1.2px 1.2px at 58% 60%, rgba(255,200,230,.4), transparent 60%);
    animation: hhTwinkle 8s ease-in-out infinite alternate;
  }
  @keyframes hhTwinkle { 0% { opacity: .45 } 100% { opacity: .9 } }

  .hh-aurora { position: absolute; z-index: 0; border-radius: 50%; filter: blur(70px); pointer-events: none; }
  .hh-aurora.a { width: 60vw; height: 60vw; left: -14vw; top: -12vw; background: radial-gradient(circle, rgba(255,94,138,.22), transparent 62%); animation: hhDrift1 19s ease-in-out infinite; }
  .hh-aurora.b { width: 56vw; height: 56vw; right: -12vw; top: -6vw; background: radial-gradient(circle, rgba(100,210,255,.2), transparent 62%); animation: hhDrift2 23s ease-in-out infinite; }
  .hh-aurora.c { width: 64vw; height: 64vw; left: 50%; bottom: -28vw; transform: translateX(-50%); background: radial-gradient(circle, rgba(162,89,255,.2), transparent 62%); animation: hhDrift3 27s ease-in-out infinite; }
  @keyframes hhDrift1 { 0%,100% { transform: translate(0,0) } 50% { transform: translate(4vw,3vw) } }
  @keyframes hhDrift2 { 0%,100% { transform: translate(0,0) } 50% { transform: translate(-3vw,4vw) } }
  @keyframes hhDrift3 { 0%,100% { transform: translateX(-50%) translateY(0) } 50% { transform: translateX(-50%) translateY(-3vw) } }

  .hh-fx { position: absolute; inset: 0; z-index: 1; width: 100%; height: 100%; pointer-events: none; }
  .hh-corefb {
    position: absolute; z-index: 1; left: 50%; top: 46%; width: 46vmin; height: 46vmin; transform: translate(-50%,-50%); border-radius: 50%; pointer-events: none;
    background: radial-gradient(circle, rgba(255,255,255,.5), rgba(162,89,255,.32) 30%, rgba(41,151,255,.16) 52%, transparent 70%); filter: blur(8px); opacity: 0;
    animation: hhIgnite 1.1s cubic-bezier(.16,1,.3,1) .2s forwards, hhCoreb 6.5s ease-in-out 1.3s infinite;
  }
  @keyframes hhIgnite { from { opacity: 0; transform: translate(-50%,-50%) scale(.4) } to { opacity: 1; transform: translate(-50%,-50%) scale(1) } }
  @keyframes hhCoreb { 0%,100% { opacity: .85; transform: translate(-50%,-50%) scale(1) } 50% { opacity: 1; transform: translate(-50%,-50%) scale(1.08) } }
  .hh-scrim {
    position: absolute; z-index: 2; left: 50%; top: 50%; width: min(120vw,1100px); height: min(80vh,640px); transform: translate(-50%,-50%); pointer-events: none;
    background: radial-gradient(60% 50% at 50% 50%, rgba(6,6,11,.62), rgba(6,6,11,.28) 55%, transparent 76%);
  }

  .hh-wrap {
    position: relative; z-index: 3; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
    padding: calc(var(--nav) + 3vh) clamp(22px,5vw,40px) 11vh;
  }
  .hh-reveal { opacity: 1; }

  .hh-eyebrow { margin: 0 0 clamp(20px,3vh,30px); font-size: clamp(11.5px,1.3vw,14px); font-weight: 600; letter-spacing: .32em; text-transform: uppercase; color: var(--ink-3, #6f74a0); }
  .hh.is-ar .hh-eyebrow { letter-spacing: .12em; }

  .hh-h { margin: 0; font-weight: 860; letter-spacing: -.04em; line-height: 1.02; font-size: clamp(38px,7.6vw,104px); text-wrap: balance; max-width: 14ch; }
  .hh-l1 { display: block; color: var(--ink, #f3f4ff); }
  .hh-l2 {
    display: block;
    background: linear-gradient(100deg, var(--pink), var(--violet) 34%, var(--blue) 66%, var(--cyan));
    background-size: 220% 100%;
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;
    filter: drop-shadow(0 6px 40px rgba(120,110,255,.35)); animation: hhShimmer 9s ease-in-out infinite;
  }
  @keyframes hhShimmer { 0%,100% { background-position: 0% 50% } 50% { background-position: 100% 50% } }
  .hh.is-ar .hh-h { letter-spacing: 0; line-height: 1.14; font-size: clamp(30px,6.2vw,86px); max-width: 18ch; }

  .hh-lead { margin: clamp(22px,3.4vh,34px) 0 0; font-size: clamp(15px,1.8vw,21px); font-weight: 450; line-height: 1.5; color: var(--ink-2, #aab0d6); max-width: 46ch; }
  .hh.is-ar .hh-lead { font-size: clamp(16px,1.95vw,23px); line-height: 1.7; max-width: 38ch; }

  .hh-cta { margin-top: clamp(26px,4vh,40px); display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .hh-btn {
    display: inline-flex; align-items: center; gap: 9px; padding: clamp(13px,1.6vw,17px) clamp(22px,2.6vw,30px); border-radius: 999px;
    font-size: clamp(14px,1.5vw,17px); font-weight: 600; letter-spacing: -.01em; cursor: pointer; text-decoration: none; border: 1px solid transparent;
    transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s ease, background .3s ease, border-color .3s ease;
  }
  .hh-btn:focus-visible { outline: 2px solid var(--cyan); outline-offset: 3px; }
  .hh-arr { display: inline-block; transition: transform .3s cubic-bezier(.16,1,.3,1); }
  .hh-btn--primary { color: #fff; background: linear-gradient(120deg, var(--blue), var(--violet)); box-shadow: 0 14px 40px -14px rgba(80,120,255,.8), inset 0 1px 0 rgba(255,255,255,.25); }
  .hh-btn--primary:hover { transform: translateY(-3px); box-shadow: 0 22px 56px -16px rgba(100,120,255,.95), inset 0 1px 0 rgba(255,255,255,.3); }
  .hh-btn--primary:hover .hh-arr { transform: translateX(5px); }
  .hh.is-ar .hh-btn--primary:hover .hh-arr { transform: translateX(-5px); }
  .hh-btn--ghost { color: var(--ink, #f3f4ff); background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.16); backdrop-filter: blur(8px); }
  .hh-btn--ghost:hover { transform: translateY(-3px); background: rgba(255,255,255,.09); border-color: rgba(255,255,255,.3); box-shadow: 0 16px 40px -18px rgba(120,140,255,.6); }

  .hh-scroll {
    position: absolute; z-index: 3; left: 50%; bottom: clamp(20px,3.4vh,34px); transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 11.5px; letter-spacing: .26em; text-transform: uppercase; color: var(--ink-3, #6f74a0); animation: hhCue 2.6s ease-in-out 1.4s infinite;
  }
  .hh.is-ar .hh-scroll { letter-spacing: .08em; }
  @keyframes hhCue { 0%,100% { transform: translateX(-50%) translateY(0); opacity: .7 } 50% { transform: translateX(-50%) translateY(5px); opacity: 1 } }
  .hh-scroll svg { width: 16px; height: 22px; }

  /* Light theme: lift the canvas/scrim so dark-on-light text stays legible. */
  :global([data-theme='light']) .hh { background: radial-gradient(140% 120% at 50% 42%, #eef1fb 0%, #f5f6fb 52%, #fbfbfe 100%); }
  :global([data-theme='light']) .hh-scrim { background: radial-gradient(60% 50% at 50% 50%, rgba(245,246,251,.7), rgba(245,246,251,.3) 55%, transparent 76%); }
  :global([data-theme='light']) .hh-l1 { color: #0b0b14; }
  :global([data-theme='light']) .hh-eyebrow,
  :global([data-theme='light']) .hh-scroll { color: #5b6080; }
  :global([data-theme='light']) .hh-lead { color: #3a3f5c; }

  @media (max-width: 560px) {
    .hh-scrim { background: radial-gradient(70% 46% at 50% 50%, rgba(6,6,11,.72), rgba(6,6,11,.3) 58%, transparent 80%); }
    .hh-cta { width: 100%; }
    .hh-btn { flex: 1 1 auto; justify-content: center; }
  }
</style>

<script>
  // Converging-light canvas + entrance reveal for the hero. Guarded + re-bound
  // for Astro View Transitions; tears down the old rAF on re-init.
  let heroRaf: number | null = null;
  let heroCleanup: (() => void) | null = null;

  function initHero() {
    heroCleanup?.();
    const cv = document.getElementById('heroFx') as HTMLCanvasElement | null;
    if (!cv) return;
    const ctx = cv.getContext('2d');
    if (!ctx) return;

    const section = cv.closest('.hh') as HTMLElement;
    const reveals = Array.from(section.querySelectorAll<HTMLElement>('.hh-reveal'));
    reveals.forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(22px)';
    });
    const coreFb = section.querySelector<HTMLElement>('.hh-corefb');
    if (coreFb) coreFb.style.display = 'none';

    let W = 0, H = 0, cx = 0, cy = 0, maxR = 0;
    const dpr = Math.min(2, window.devicePixelRatio || 1);
    const SPECTRUM = ['#ff5e8a', '#a259ff', '#2997ff', '#64d2ff'];
    type P = { a: number; r: number; v: number; col: string; sz: number; jit: number };
    let parts: P[] = [];
    let N = 0;
    const start = performance.now();
    let litAt = 0;

    const rgba = (hex: string, a: number) => {
      const n = parseInt(hex.slice(1), 16);
      return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`;
    };
    const mk = (seed: boolean): P => {
      const a = Math.random() * Math.PI * 2;
      const ci = (Math.floor((a / (Math.PI * 2)) * 4) + (Math.random() < 0.18 ? 1 : 0)) % 4;
      return { a, r: (seed ? Math.random() : 1) * maxR * (0.7 + Math.random() * 0.35), v: 0.0009 + Math.random() * 0.0014, col: SPECTRUM[ci], sz: 0.7 + Math.random() * 1.7, jit: (Math.random() - 0.5) * 0.0016 };
    };
    const build = () => { parts = []; for (let i = 0; i < N; i++) parts.push(mk(true)); };
    const resize = () => {
      W = cv.clientWidth; H = cv.clientHeight; cv.width = W * dpr; cv.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cx = W * 0.5; cy = H * 0.5; maxR = Math.sqrt(cx * cx + cy * cy) * 1.04;
      N = Math.max(70, Math.min(170, Math.round((W * H) / 9000)));
      build();
    };

    const frame = (now: number) => {
      if (!litAt) litAt = now;
      const t = now - start, rt = now - litAt;
      for (let k = 0; k < reveals.length; k++) {
        const rd = 240 + k * 150, rp = Math.max(0, Math.min(1, (rt - rd) / 850)), re = 1 - Math.pow(1 - rp, 3);
        reveals[k].style.opacity = String(re);
        reveals[k].style.transform = `translateY(${(22 * (1 - re)).toFixed(1)}px)`;
      }
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      let ign = Math.min(1, (now - litAt) / 900); ign = litAt ? 1 - Math.pow(1 - ign, 3) : 0;
      const pulse = 0.5 + 0.5 * Math.sin((t / 6500) * Math.PI * 2);
      const coreR = Math.min(W, H) * 0.16 * (0.92 + 0.12 * pulse) * (0.5 + 0.5 * ign);
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreR * 2.4);
      g.addColorStop(0, rgba('#ffffff', 0.9 * ign));
      g.addColorStop(0.18, rgba('#cdd9ff', 0.5 * ign));
      g.addColorStop(0.4, rgba('#a259ff', 0.26 * ign));
      g.addColorStop(0.7, rgba('#2997ff', 0.1 * ign));
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(cx, cy, coreR * 2.4, 0, Math.PI * 2); ctx.fill();

      for (let i = 0; i < parts.length; i++) {
        const p = parts[i];
        p.a += p.jit;
        p.r -= p.v * maxR * (0.32 + p.r / maxR);
        if (p.r < coreR * 0.42) { parts[i] = mk(false); continue; }
        const x = cx + Math.cos(p.a) * p.r, y = cy + Math.sin(p.a) * p.r;
        const tn = 1 - p.r / maxR;
        const alpha = Math.sin(Math.max(0, Math.min(1, tn)) * Math.PI) * 0.9 * ign;
        if (alpha <= 0.01) continue;
        const tail = p.v * maxR * 9 * (0.4 + tn);
        const tx = cx + Math.cos(p.a) * (p.r + tail), ty = cy + Math.sin(p.a) * (p.r + tail);
        const lg = ctx.createLinearGradient(x, y, tx, ty);
        lg.addColorStop(0, rgba(p.col, alpha));
        lg.addColorStop(1, rgba(p.col, 0));
        ctx.strokeStyle = lg; ctx.lineWidth = p.sz; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(tx, ty); ctx.stroke();
        ctx.fillStyle = rgba(p.col, alpha); ctx.beginPath(); ctx.arc(x, y, p.sz * 0.8, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      heroRaf = requestAnimationFrame(frame);
    };

    window.addEventListener('resize', resize);
    resize();
    heroRaf = requestAnimationFrame(frame);
    heroCleanup = () => {
      if (heroRaf) cancelAnimationFrame(heroRaf);
      heroRaf = null;
      window.removeEventListener('resize', resize);
      heroCleanup = null;
    };
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
