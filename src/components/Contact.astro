---
import { profile } from '../data/profile';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const ar = lang === 'ar';

const kicker = ar ? 'لنتحدّث' : 'Let’s talk';
const h2 = ar ? 'وظِّف واحدًا.<br>واحصل على فريق.' : 'Hire one.<br>Get a team.';
const lead = ar
  ? 'متاحٌ لوظائف التسويق وعملياته وأتمتة الذكاء الاصطناعي في الكويت ودول الخليج.'
  : 'Open to marketing, marketing-ops, and AI-automation roles in Kuwait & the GCC.';
const sign = ar ? 'متاحٌ الآن · الكويت ودول الخليج' : 'Available now · Kuwait & the GCC';

const channels = [
  {
    href: profile.contact.whatsapp,
    name: 'WhatsApp',
    sub: ar ? 'أسرع طريقة للوصول إليّ' : 'the fastest way to reach me',
    ext: true,
    // WhatsApp glyph
    path: 'M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.004c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01zM12.04 20.15h-.003a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23a8.2 8.2 0 0 1 8.23 8.24c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z',
  },
  {
    href: `mailto:${profile.contact.email}`,
    name: 'Email',
    sub: profile.contact.email,
    ext: false,
    // envelope
    path: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v.01l8 5 8-5V6H4zm16 2.24-7.46 4.66a1 1 0 0 1-1.08 0L4 8.24V18h16V8.24z',
  },
  {
    href: profile.contact.linkedin,
    name: 'LinkedIn',
    sub: ar ? 'ملفي المهني' : 'my professional profile',
    ext: true,
    // LinkedIn glyph
    path: 'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm6 0h3.83v1.64h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.49c0-1.31-.02-3-1.83-3-1.83 0-2.11 1.43-2.11 2.9V21H9V9z',
  },
];
---

<section class="finale" id="contact" data-pin style="height:200vh">
  <div class="finale__stage" data-stage>
    <!-- converging glow — scales as the section scrubs into view -->
    <div class="finale__aura" aria-hidden="true">
      <span class="finale__blob finale__blob--a"></span>
      <span class="finale__blob finale__blob--b"></span>
      <span class="finale__blob finale__blob--c"></span>
      <span class="finale__core"></span>
    </div>

    <div class="finale__inner">
      <p class="finale__kicker" data-step data-glow>{kicker}</p>
      <h2 class="finale__h" data-step data-glow set:html={h2}></h2>
      <p class="finale__lead" data-step>{lead}</p>

      <div class="finale__cards" data-step>
        {
          channels.map((c) => (
            <a
              class="fcontact"
              href={c.href}
              {...(c.ext ? { target: '_blank', rel: 'noopener' } : {})}
            >
              <span class="fcontact__ic">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d={c.path} fill="currentColor" />
                </svg>
              </span>
              <span class="fcontact__txt">
                <b>{c.name}</b>
                <i dir="ltr">{c.sub}</i>
              </span>
              <span class="fcontact__go" aria-hidden="true">{ar ? '←' : '→'}</span>
            </a>
          ))
        }
      </div>

      <p class="finale__sign" data-step>
        <span class="finale__dot" aria-hidden="true"></span>
        {sign}
      </p>
    </div>
  </div>
</section>

<style>
  .finale {
    position: relative;
    z-index: 1;
  }
  .finale__stage {
    position: sticky;
    top: 0;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 80px clamp(20px, 5vw, 40px);
  }

  /* converging glow background, driven by the biome --p (0→1) */
  .finale__aura {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .finale__blob {
    position: absolute;
    left: 50%;
    top: 48%;
    border-radius: 50%;
    filter: blur(60px);
    transform: translate(-50%, -50%) scale(calc(0.55 + var(--p, 0) * 0.7));
    opacity: calc(0.16 + var(--p, 0) * 0.7);
  }
  .finale__blob--a {
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(41, 151, 255, 0.5), transparent 62%);
  }
  .finale__blob--b {
    width: 44vw;
    height: 44vw;
    left: 62%;
    background: radial-gradient(circle, rgba(191, 90, 242, 0.45), transparent 62%);
  }
  .finale__blob--c {
    width: 40vw;
    height: 40vw;
    left: 38%;
    top: 58%;
    background: radial-gradient(circle, rgba(48, 209, 88, 0.32), transparent 64%);
  }
  .finale__core {
    position: absolute;
    left: 50%;
    top: 48%;
    width: min(30vw, 320px);
    height: min(30vw, 320px);
    transform: translate(-50%, -50%) scale(calc(0.5 + var(--p, 0) * 0.7));
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.7), rgba(150, 196, 255, 0.32) 26%, transparent 60%);
    filter: blur(6px);
    opacity: calc(0.14 + var(--p, 0) * 0.7);
  }

  /* reveal-in: the biome engine (lib/biome.ts) raises these as the section
     scrubs into view; hidden at rest so they animate in (JS-gated home). */
  .finale [data-step] {
    opacity: 0;
    transform: translateY(32px);
    will-change: transform, opacity;
  }
  .finale__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 760px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .finale__kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1.4vw, 14px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .finale__h {
    font-size: clamp(44px, 9vw, 120px);
    font-weight: 850;
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 16px 0 0;
    color: var(--ink);
  }
  [dir='rtl'] .finale__h {
    letter-spacing: 0;
    line-height: 1.14;
  }
  .finale__lead {
    color: var(--ink-2);
    font-size: clamp(17px, 2.2vw, 22px);
    line-height: 1.5;
    max-width: 30ch;
    margin: 22px 0 0;
  }
  [dir='rtl'] .finale__lead {
    max-width: 38ch;
    line-height: 1.8;
  }

  /* the three premium contact cards */
  .finale__cards {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-top: 40px;
  }
  .fcontact {
    display: flex;
    align-items: center;
    gap: 15px;
    text-align: start;
    text-decoration: none;
    padding: 18px 20px;
    border-radius: 18px;
    border: 1px solid var(--glass-brd, rgba(255, 255, 255, 0.12));
    background: var(--glass-bg, rgba(255, 255, 255, 0.05));
    backdrop-filter: saturate(160%) blur(20px);
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    color: var(--ink);
    transition: transform 0.4s var(--ease), border-color 0.3s, box-shadow 0.4s, background 0.3s;
  }
  .fcontact:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, var(--glass-bg, rgba(255, 255, 255, 0.05)));
    box-shadow: 0 22px 50px -24px color-mix(in srgb, var(--accent) 75%, transparent),
      0 0 40px -10px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .fcontact__ic {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 13px;
    color: var(--accent-ink);
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .fcontact__ic svg {
    width: 24px;
    height: 24px;
    display: block;
  }
  .fcontact__txt {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }
  .fcontact__txt b {
    font-size: 17px;
    font-weight: 700;
  }
  .fcontact__txt i {
    font-style: normal;
    font-size: 13px;
    color: var(--ink-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  [dir='rtl'] .fcontact__txt i {
    text-align: start;
  }
  .fcontact__go {
    flex: 0 0 auto;
    font-size: 20px;
    color: var(--ink-3);
    transition: transform 0.3s var(--ease), color 0.3s;
  }
  .fcontact:hover .fcontact__go {
    color: var(--accent-ink);
    transform: translateX(4px);
  }
  [dir='rtl'] .fcontact:hover .fcontact__go {
    transform: translateX(-4px);
  }

  .finale__sign {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 34px;
    font-family: var(--font-mono);
    font-size: clamp(12px, 1.4vw, 14px);
    letter-spacing: 0.06em;
    color: var(--ink-2);
  }
  .finale__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #30d158;
    box-shadow: 0 0 12px #30d158;
    animation: finalePulse 2.4s var(--ease) infinite;
  }
  @keyframes finalePulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.78); }
  }

  @media (max-width: 820px) {
    .finale__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
