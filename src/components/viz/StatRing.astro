---
import { pick, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  /** 0–100 fill of the ring */
  pct: number;
  /** big text in the centre, e.g. "59/59" or "96–100" */
  display: string;
  label: { en: string; ar: string };
  sub?: { en: string; ar: string };
}
const { lang, pct, display, label, sub } = Astro.props;
const r = 52;
const c = +(2 * Math.PI * r).toFixed(1);
const off = +(c * (1 - Math.min(100, Math.max(0, pct)) / 100)).toFixed(1);
---

<div class="ring reveal" style={`--c:${c};--off:${off}`}>
  <svg viewBox="0 0 120 120" class="ring__svg" aria-hidden="true">
    <circle class="ring__bg" cx="60" cy="60" r={r}></circle>
    <circle class="ring__fg" cx="60" cy="60" r={r}></circle>
  </svg>
  <div class="ring__c">
    <span class="ring__num gradient-text">{display}</span>
  </div>
  <div class="ring__lbl">{pick(lang, label)}</div>
  {sub && <div class="ring__sub">{pick(lang, sub)}</div>}
</div>

<style>
  .ring { display: grid; justify-items: center; text-align: center; position: relative; }
  .ring__svg { width: clamp(150px, 24vw, 210px); height: clamp(150px, 24vw, 210px); transform: rotate(-90deg); }
  .ring__bg { fill: none; stroke: var(--panel-brd); stroke-width: 9; }
  .ring__fg {
    fill: none; stroke: var(--accent); stroke-width: 9; stroke-linecap: round;
    stroke-dasharray: var(--c); stroke-dashoffset: var(--c);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--accent) 70%, transparent));
    transition: stroke-dashoffset 1.5s var(--ease);
  }
  .ring.in .ring__fg { stroke-dashoffset: var(--off); }
  .ring__c {
    position: absolute; inset: 0; display: grid; place-items: center;
    top: 0; bottom: clamp(46px, 9vw, 64px);
  }
  .ring__num { font-size: clamp(30px, 5vw, 46px); font-weight: 900; letter-spacing: -.03em; }
  .ring__lbl { margin-top: 6px; font-size: 15px; color: var(--ink); font-weight: 600; }
  .ring__sub { margin-top: 2px; font-size: 12.5px; color: var(--ink-2); }
  @media (prefers-reduced-motion: reduce) { .ring__fg { transition: none; stroke-dashoffset: var(--off); } }
</style>
