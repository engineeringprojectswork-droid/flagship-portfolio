---
/**
 * Selected Work — the signature moment: a pinned, horizontally-scrubbed film
 * strip of the story cards driven by vertical scroll (lib/home.ts). Each card
 * is colour-coded to its domain accent with a real-screenshot thumbnail slot.
 * On mobile / reduced-motion it degrades to a stacked card grid.
 */
import { projects, accentHex } from '../data/projects';
import { useTranslations, pick, workPath, type Lang } from '../i18n/utils';
import AssetSlot from './work/spine/AssetSlot.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const n = projects.length;
const countWord =
  lang === 'ar'
    ? ({ 8: 'ثماني', 9: 'تسع', 10: 'عشر' } as Record<number, string>)[n] ?? String(n)
    : ({ 8: 'Eight', 9: 'Nine', 10: 'Ten' } as Record<number, string>)[n] ?? String(n);

const heading =
  lang === 'ar' ? `${countWord} قصص.<br>كل رقمٍ حقيقي.` : `${countWord} stories.<br>Every number is real.`;
const sub =
  lang === 'ar'
    ? 'مرّر — يتحرّك الشريط أفقيًا. افتح أيًّا منها.'
    : 'Scroll — the strip travels sideways. Open any one.';
const kicker = lang === 'ar' ? 'أعمالٌ مختارة' : 'Selected work';
---

<section class="section work" id="work" data-home-motion>
  <div class="wrap">
    <div class="center stack" style="max-width:760px;margin-inline:auto">
      <p class="kicker reveal">{kicker}</p>
      <h2 class="h-xl reveal d1" set:html={heading}></h2>
      <p class="lead reveal d2">{sub}</p>
    </div>
  </div>

  <div class="filmstrip" data-filmstrip>
    <div class="filmstrip__sticky" data-filmstrip-sticky>
      <div class="filmstrip__head">
        <span class="filmstrip__live"><i></i>{lang === 'ar' ? 'مباشر · مرّر للتصفّح ←' : 'Live · scroll to scrub →'}</span>
        <span class="filmstrip__progress"><i data-filmstrip-bar></i></span>
      </div>
      <div class="filmstrip__track" data-filmstrip-track>
        {
          projects.map((p, i) => (
            <a class="fcard" href={workPath(lang, p.slug)} style={`--ca:${accentHex[p.accent]}`}>
              <span class="fcard__strip" aria-hidden="true" />
              <div class="fcard__thumb">
                <AssetSlot
                  lang={lang}
                  ratio="16/10"
                  label={{ en: `${p.title.en} — screenshot`, ar: `${p.title.ar} — لقطة` }}
                />
              </div>
              <div class="fcard__body">
                <div class="fcard__meta">
                  <span class="fcard__idx">{String(i + 1).padStart(2, '0')}</span>
                  <span class="fcard__tag">{pick(lang, p.tag)}</span>
                </div>
                <h3>{pick(lang, p.title)}</h3>
                <p>{pick(lang, p.blurb)}</p>
                <span class="fcard__stat">
                  {pick(lang, p.stat)} <span class="muted">{pick(lang, p.statNote)}</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
