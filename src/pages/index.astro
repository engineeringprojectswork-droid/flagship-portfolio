---
// Root entry. Statically rendered, then redirects to /en or /ar based on the
// visitor's saved choice or browser language. Crawlers/no-JS get the noscript
// meta-refresh + hreflang (English default).
// Base-aware: under a GitHub Pages project site everything lives at
// `/flagship-portfolio/…`, so links + the JS redirect are built on BASE_URL.
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // "" at root, "/flagship-portfolio" on Pages
const enUrl = new URL(`${base}/en`, Astro.site).href;
const arUrl = new URL(`${base}/ar`, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mohamed Mahmoud — A whole marketing team, in one person</title>
    <link rel="canonical" href={enUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="ar" href={arUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <meta name="robots" content="noindex, follow" />
    <script is:inline define:vars={{ base }}>
      (() => {
        try {
          const saved = localStorage.getItem('mm-lang');
          const lang =
            saved === 'ar' || saved === 'en'
              ? saved
              : (navigator.language || 'en').toLowerCase().startsWith('ar')
                ? 'ar'
                : 'en';
          location.replace(base + '/' + lang);
        } catch (e) {
          location.replace(base + '/en');
        }
      })();
    </script>
    <noscript><meta http-equiv="refresh" content={`0; url=${base}/en`} /></noscript>
  </head>
  <body style="background:#000;color:#f5f5f7;font-family:system-ui">
    <p style="padding:2rem">
      Redirecting… <a style="color:#2997ff" href={`${base}/en`}>English</a> ·
      <a style="color:#2997ff" href={`${base}/ar`}>العربية</a>
    </p>
  </body>
</html>
