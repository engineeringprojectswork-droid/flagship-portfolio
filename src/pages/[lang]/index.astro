---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Contact from '../../components/Contact.astro';
import { useTranslations, workPath, pick, type Lang } from '../../i18n/utils';
import { locales } from '../../i18n/utils';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const ar = lang === 'ar';

// Selected-work strip — ALL 9 case stories, in canonical order, deep-linking to
// each story page. Built from src/data/projects.ts (single source of truth) so
// the strip never drifts out of sync with the story routes/copy/numbers.
const cards = projects.map((p, i) => ({
  slug: p.slug,
  n: String(i + 1).padStart(2, '0'),
  tag: pick(lang, p.tag),
  title: pick(lang, p.title),
  sub: pick(lang, p.blurb),
  stat: pick(lang, p.stat),
  note: pick(lang, p.statNote),
  ca: p.cardA,
  cb: p.cardB,
}));

// Biome 04 ("I shape the brand") — 16 dots that start scattered (--sx/--sy) and
// converge onto a clean ring (--ex/--ey) as --p rises: chaos → a shaped mark.
// Deterministic (fixed seed table, no Math.random) so SSR output is stable.
const SEED = [0.42, -0.78, 0.55, -0.31, 0.86, -0.59, 0.18, -0.91, 0.67, -0.23, 0.74, -0.49, 0.09, -0.66, 0.38, -0.85];
const brandDots = Array.from({ length: 16 }, (_, i) => {
  const a = (i / 16) * Math.PI * 2;
  return {
    ex: +(Math.cos(a) * 18).toFixed(2), // ring radius in vmin
    ey: +(Math.sin(a) * 18).toFixed(2),
    sx: +(SEED[i] * 34).toFixed(2), // scattered start in vmin
    sy: +(SEED[(i * 7 + 3) % 16] * 30).toFixed(2),
  };
});
---

<BaseLayout
  lang={lang}
  title={t('site.title')}
  description={t('site.description')}
  path={`/${lang}`}
  accent="blue"
  home={true}
>
  <!-- scroll-progress meter (driven by initBiome) -->
  <div
    data-bm-progress
    aria-hidden="true"
    style="position:fixed;top:0;inset-inline-start:0;height:2px;width:0;z-index:60;background:linear-gradient(100deg,#ff5e8a,#a259ff,#2997ff,#64d2ff);box-shadow:0 0 12px #a259ff;pointer-events:none"
  >
  </div>

  <!-- film grain — cinematic finish shared across every biome -->
  <div
    aria-hidden="true"
    style="position:fixed;inset:0;z-index:42;pointer-events:none;mix-blend-mode:soft-light;opacity:.28"
  >
    <svg width="100%" height="100%" preserveAspectRatio="none" style="position:absolute;inset:0">
      <filter id="bmGrain"><feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="2" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter>
      <rect width="100%" height="100%" filter="url(#bmGrain)"></rect>
    </svg>
  </div>

  <Hero lang={lang} />

  <!-- ============ BIOME 01 · PAID SOCIAL · blue nebula bloom ============ -->
  <section data-pin style="position:relative;z-index:1;height:280vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <!-- 01 · I run the ads → precision targeting: the reticle locks on while
           "reach" rings ripple outward (impressions spreading to an audience). -->
      <div class="sc b1-glow" aria-hidden="true"></div>
      <div class="sc b1" aria-hidden="true">
        <span class="b1-reach r1"></span><span class="b1-reach r2"></span><span class="b1-reach r3"></span>
        <span class="b1-sweep"></span>
        <span class="b1-cross h"></span><span class="b1-cross v"></span>
        <span class="b1-ring"></span>
        <span class="b1-dot"></span>
      </div>
      <div class="bm-tag" style="--c:#2997ff"><span class="bm-num">01</span><span class="bm-sl">/</span><span>{ar ? 'إعلانات مدفوعة' : 'Paid Social'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'يقفل على الهدف' : 'lock on target'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="lock" data-split="letter">{ar ? 'أُدير الإعلانات.' : 'I run the ads.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? '٢٠٦ عميل واتساب · ٠٫٨٤$ للعميل' : '206 WhatsApp leads · $0.84 each'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 02 · AUDIENCE GROWTH · star-warp + scrubbed count ============ -->
  <section data-pin style="position:relative;z-index:1;height:330vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <div style="position:absolute;left:50%;top:50%;width:200vmax;height:200vmax;transform:translate(-50%,-50%) rotate(calc(var(--p,0)*90deg)) scale(calc(.7 + var(--p,0)*.6));background:repeating-conic-gradient(from 0deg, transparent 0 .5deg, rgba(255,94,138,.5) .5deg .85deg, transparent .85deg 1.9deg);mask:radial-gradient(circle, transparent 10%, #000 46%, transparent 86%);-webkit-mask:radial-gradient(circle, transparent 10%, #000 46%, transparent 86%);opacity:calc(.16 + var(--p,0)*.6);pointer-events:none"></div>
      <div style="position:absolute;left:50%;top:50%;width:200vmax;height:200vmax;transform:translate(-50%,-50%) rotate(calc(var(--p,0)*-70deg)) scale(calc(.6 + var(--p,0)*.7));background:repeating-conic-gradient(from 12deg, transparent 0 .55deg, rgba(162,89,255,.45) .55deg .95deg, transparent .95deg 2.2deg);mask:radial-gradient(circle, transparent 12%, #000 50%, transparent 88%);-webkit-mask:radial-gradient(circle, transparent 12%, #000 50%, transparent 88%);opacity:calc(.12 + var(--p,0)*.5);pointer-events:none"></div>
      <div style="position:absolute;left:50%;top:50%;width:42vw;height:42vw;transform:translate(-50%,-50%) scale(calc(.5 + var(--p,0)*1));border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.55),rgba(255,94,138,.22) 30%,transparent 64%);filter:blur(8px);opacity:calc(.14 + var(--p,0)*.6);pointer-events:none"></div>
      <div class="bm-tag" style="--c:#ff5e8a"><span class="bm-num">02</span><span class="bm-sl">/</span><span>{ar ? 'نموّ الجمهور' : 'Audience Growth'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'الرقم يتسلّق' : 'the number climbs'}</span></div>
      <div class="bm-copy">
        <div data-step data-glow data-climb style="font-size:clamp(64px,15vw,200px);font-weight:900;letter-spacing:-.05em;line-height:.9;font-variant-numeric:tabular-nums;color:var(--ink,#f3f4ff);opacity:0;transform:translateY(34px);will-change:transform,opacity;filter:drop-shadow(0 0 calc(var(--glow,0)*24px) rgba(var(--text-glow,170,195,255), calc(var(--glow,0)*.75)));transition:filter .18s linear">9.2K</div>
        <p data-step data-glow style="font-size:clamp(26px,5vw,52px);font-weight:850;line-height:1;letter-spacing:-.03em;color:var(--ink,#f3f4ff);margin-top:14px;opacity:0;transform:translateY(34px);will-change:transform,opacity;filter:drop-shadow(0 0 calc(var(--glow,0)*18px) rgba(var(--text-glow,170,195,255), calc(var(--glow,0)*.7)));transition:filter .18s linear">{ar ? 'أُنمّي الجمهور.' : 'I grow the audience.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? '٩٫٢ ألف ← مليون+ متابع · ٢٠٢١–٢٠٢٥' : '9.2K → 1M+ followers · 2021–2025'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 03 · MARKETING OPS · CRM · synthwave grid + rising planet ============ -->
  <section data-pin style="position:relative;z-index:1;height:300vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <div style="position:absolute;inset:auto 0 0 0;height:56%;overflow:hidden;opacity:calc(.4 + var(--p,0)*.6);pointer-events:none;perspective:340px">
        <div style="position:absolute;inset:0;transform-origin:bottom;transform:rotateX(76deg);background:repeating-linear-gradient(90deg, transparent 0 42px, color-mix(in srgb, #64d2ff 60%, transparent) 42px 44px), repeating-linear-gradient(0deg, transparent 0 42px, color-mix(in srgb, #a259ff 52%, transparent) 42px 44px);mask:linear-gradient(transparent, #000 40%);-webkit-mask:linear-gradient(transparent, #000 40%)"></div>
      </div>
      <div style="position:absolute;left:0;right:0;top:44%;height:2px;background:linear-gradient(90deg,transparent,#64d2ff,transparent);filter:blur(1px);opacity:calc(.35 + var(--p,0)*.5);box-shadow:0 0 30px #64d2ff;pointer-events:none"></div>
      <div style="position:absolute;left:50%;top:calc(60% - var(--p,0)*40%);transform:translate(-50%,-50%);width:min(30vw,300px);height:min(30vw,300px);border-radius:50%;background:radial-gradient(circle at 36% 30%, #d7ffe9, #3bd6a0 32%, #1f8f7a 56%, #123a52 80%, #0a1f33);box-shadow:0 0 80px -6px rgba(48,209,88,.5), inset -18px -12px 56px rgba(0,0,0,.55);pointer-events:none">
        <div style="position:absolute;left:50%;top:50%;width:154%;height:42%;transform:translate(-50%,-50%) rotate(-22deg);border-radius:50%;border:2px solid rgba(120,230,200,.42);box-shadow:0 0 20px rgba(100,210,255,.3)"></div>
      </div>
      <div class="bm-tag" style="--c:#30d158"><span class="bm-num">03</span><span class="bm-sl">/</span><span>{ar ? 'عمليات التسويق · CRM' : 'Marketing Ops · CRM'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'الكوكب يرتفع' : 'the planet rises'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="build">{ar ? 'أبني الأنظمة.' : 'I build the systems.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? 'نظام CRM ثنائي اللغة بـ١٢ جدولًا' : 'a 12-tab bilingual CRM'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 04 · BRAND & CONTENT · aurora ribbons ============ -->
  <section data-pin style="position:relative;z-index:1;height:280vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <!-- 04 · I shape the brand → scattered fragments converge into one clean,
           glowing mark (voice + story + art direction shaped into an identity). -->
      <div class="sc b4-glow" aria-hidden="true"></div>
      <div class="sc b4" aria-hidden="true">
        <span class="b4-ring"></span>
        {brandDots.map((d) => (
          <span class="b4-dot" style={`--ex:${d.ex};--ey:${d.ey};--sx:${d.sx};--sy:${d.sy}`} />
        ))}
        <span class="b4-core"></span>
      </div>
      <div class="bm-tag" style="--c:#a259ff"><span class="bm-num">04</span><span class="bm-sl">/</span><span>{ar ? 'العلامة والمحتوى' : 'Brand & Content'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'يتشكّل' : 'it takes shape'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="shape">{ar ? 'أصوغ العلامة.' : 'I shape the brand.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? 'الصوت · القصة · الإخراج الفني' : 'voice · story · art direction'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ SELECTED WORK · cinematic horizontal showcase (Claude Design) ============ -->
  <section id="work" data-pin class="sw" style="position:relative;z-index:1;height:560vh">
    <div data-stage class="sw-stage" style="position:sticky;top:0;height:100svh;min-height:580px;display:flex;flex-direction:column;overflow:hidden">
      <header class="sw-head">
        <div class="bm-tag" style="--c:#64d2ff;position:static;transform:none;justify-content:flex-start"><span class="bm-num">★</span><span class="bm-sl">/</span><span>{ar ? 'أعمال مختارة' : 'Selected Work'}</span></div>
        <div class="sw-headrow">
          <h2 class="sw-title" data-glow>{ar ? 'أعمال مختارة.' : 'Selected work.'}</h2>
          <span class="sw-live"><span class="sw-livedot" aria-hidden="true"></span>{ar ? 'مباشر' : 'Live'}<span class="sw-counter"> · <b id="sw-count">01</b> / {String(cards.length).padStart(2, '0')}</span></span>
        </div>
      </header>

      <div class="sw-stripwrap">
        <div data-track class="sw-strip">
          {cards.map((c) => (
            <a href={workPath(lang, c.slug)} class="sw-tile" style={`--a:${c.ca};--b:${c.cb}`} aria-label={c.title}>
              <span class="sw-idx" aria-hidden="true">{c.n}</span>
              <span class="sw-go" aria-hidden="true">{ar ? '←' : '→'}</span>
              <div class="sw-tag">{c.tag}</div>
              <div class="sw-ti">{c.title}</div>
              <div class="sw-bl">{c.sub}</div>
              <div class="sw-foot">
                <span class="sw-stat">{c.stat}</span>
                <span class="sw-note">{c.note}</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="sw-prog">
        <div class="sw-dots" id="sw-dots">{cards.map((_, i) => (<i class={i === 0 ? 'on' : ''}></i>))}</div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 05 · SOFTWARE · orbital wireframe globe ============ -->
  <section data-pin style="position:relative;z-index:1;height:280vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <div style="position:absolute;left:50%;top:45%;transform:translate(-50%,-50%) scale(calc(.7 + var(--p,0)*.42));opacity:calc(.5 + var(--p,0)*.5);pointer-events:none">
        <svg width="420" height="420" viewBox="0 0 420 420" style="filter:drop-shadow(0 0 12px rgba(100,210,255,.5));overflow:visible">
          <g fill="none" stroke="#64d2ff" stroke-opacity=".5" stroke-width="1.3">
            <circle cx="210" cy="210" r="180" stroke-opacity=".7"/>
            <ellipse cx="210" cy="210" rx="180" ry="60"/>
            <ellipse cx="210" cy="210" rx="180" ry="120"/>
            <ellipse cx="210" cy="210" rx="180" ry="170"/>
            <line x1="30" y1="210" x2="390" y2="210"/>
            <ellipse cx="210" cy="210" rx="60" ry="180"/>
            <ellipse cx="210" cy="210" rx="120" ry="180"/>
            <ellipse cx="210" cy="210" rx="170" ry="180"/>
            <line x1="210" y1="30" x2="210" y2="390"/>
          </g>
          <g style="transform-box:view-box;transform-origin:210px 210px;animation:bmRingSpin 26s linear infinite">
            <ellipse cx="210" cy="210" rx="206" ry="80" fill="none" stroke="#a259ff" stroke-opacity=".55" stroke-width="1.6"/>
            <circle cx="416" cy="210" r="5.5" fill="#64d2ff" style="filter:drop-shadow(0 0 8px #64d2ff)"/>
          </g>
        </svg>
      </div>
      <div class="bm-tag" style="--c:#64d2ff"><span class="bm-num">05</span><span class="bm-sl">/</span><span>{ar ? 'البرمجيات' : 'Software'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'الكرة تتجمّع' : 'the globe assembles'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="compile">{ar ? 'أُطلق التطبيقات.' : 'I ship the software.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? 'تطبيق سطح مكتب بـ١٥ جدولًا · ٥٩/٥٩ اختبارًا' : 'a 15-table desktop app · 59/59 tests'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 06 · AUTOMATION · comet stream ============ -->
  <section data-pin style="position:relative;z-index:1;height:280vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <!-- 06 · I automate the rest with AI → a self-running pipeline: task tokens
           stream IN → through the AI core → OUT, on an endless loop (it runs by
           itself; scroll powers it up). -->
      <div class="sc b6-glow" aria-hidden="true"></div>
      <div class="sc b6" aria-hidden="true">
        <span class="b6-rail"></span>
        <span class="b6-tok t1"></span><span class="b6-tok t2"></span><span class="b6-tok t3"></span><span class="b6-tok t4"></span><span class="b6-tok t5"></span>
        <span class="b6-node in"></span>
        <span class="b6-node out"></span>
        <span class="b6-core"><i></i></span>
      </div>
      <div class="bm-tag" style="--c:#ffd60a"><span class="bm-num">06</span><span class="bm-sl">/</span><span>{ar ? 'الأتمتة' : 'Automation'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'يعمل تلقائيًا' : 'it runs itself'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="pipeline" style="font-size:clamp(38px,8vw,100px)">{ar ? 'وأُشغّل الباقي آليًا بالذكاء الاصطناعي.' : 'I automate the rest with AI.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? '١٤٢ سيرة ذاتية · ٧ نصوص برمجية · ٣ مهام مجدولة' : '142 résumés · 7 scripts · 3 scheduled jobs'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 07 · WEB · LIVE · constellation network ============ -->
  <section data-pin style="position:relative;z-index:1;height:280vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <!-- 07 · I put it on the web → a live site loads in a browser: the URL
           fills, content blocks load in, and the green LIVE badge lights up
           (shipped, in production). A faint wireframe globe = the open web. -->
      <div class="sc b7-globe" aria-hidden="true"></div>
      <div class="sc b7" aria-hidden="true">
        <div class="b7-win">
          <div class="b7-bar"><i></i><i></i><i></i><span class="b7-url"></span></div>
          <div class="b7-body">
            <span class="b7-block a"></span><span class="b7-block b"></span><span class="b7-block c"></span>
          </div>
          <span class="b7-live">{ar ? '● مباشر' : '● LIVE'}</span>
        </div>
      </div>
      <div class="bm-tag" style="--c:#7574ee"><span class="bm-num">07</span><span class="bm-sl">/</span><span>{ar ? 'الويب · مباشر' : 'Web · Live'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'يُنشر مباشرةً' : 'deploys live'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="render">{ar ? 'وأنشره على الويب.' : 'I put it on the web.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? 'مباشر · مُطلق · في الإنتاج' : 'live · shipped · in production'}</span></div>
      </div>
    </div>
  </section>

  <!-- ============ BIOME 08 · AI OPERATING MODEL · convergence finale ============ -->
  <section data-pin style="position:relative;z-index:1;height:340vh">
    <div data-stage style="position:sticky;top:0;height:100svh;min-height:580px;display:grid;place-items:center;text-align:center;overflow:hidden">
      <div style="position:absolute;left:50%;top:44%;transform:translate(-50%,-50%);width:min(86vw,920px);height:min(86vw,920px);pointer-events:none">
        <div style="position:absolute;left:50%;top:50%;width:44%;height:44%;transform:translate(-50%,-50%) scale(calc(.28 + var(--p,0)*1.05));border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.95),rgba(255,159,10,.5) 18%,rgba(162,89,255,.3) 42%,transparent 66%);filter:blur(6px);opacity:calc(.18 + var(--p,0)*.82);animation:corePulse 6s ease-in-out infinite"></div>
        <div style="position:absolute;left:50%;top:50%;width:16%;height:16%;transform:translate(-50%,-50%) scale(calc(.4 + var(--p,0)*1));border-radius:50%;border:1px solid rgba(255,255,255,calc(.1 + var(--p,0)*.5));opacity:calc(var(--p,0))"></div>
        <div style="position:absolute;left:50%;top:50%;width:18px;height:18px;border-radius:50%;background:#ff5e8a;box-shadow:0 0 22px 5px rgba(255,94,138,.7);transform:translate(-50%,-50%) translate(calc((1 - var(--p,0)) * -300px), calc((1 - var(--p,0)) * -160px))"></div>
        <div style="position:absolute;left:50%;top:50%;width:18px;height:18px;border-radius:50%;background:#2997ff;box-shadow:0 0 22px 5px rgba(41,151,255,.7);transform:translate(-50%,-50%) translate(calc((1 - var(--p,0)) * 310px), calc((1 - var(--p,0)) * -120px))"></div>
        <div style="position:absolute;left:50%;top:50%;width:18px;height:18px;border-radius:50%;background:#ff9f0a;box-shadow:0 0 22px 5px rgba(255,159,10,.7);transform:translate(-50%,-50%) translate(calc((1 - var(--p,0)) * 30px), calc((1 - var(--p,0)) * 300px))"></div>
      </div>
      <div class="bm-tag" style="--c:#ff9f0a"><span class="bm-num">08</span><span class="bm-sl">/</span><span>{ar ? 'نموذج تشغيل بالذكاء' : 'AI Operating Model'}</span><span class="bm-sl">·</span><span style="opacity:.7">{ar ? 'كلٌّ يتلاقى' : 'everything converges'}</span></div>
      <div class="bm-copy">
        <p data-glow class="bm-h" data-fx="unify">{ar ? 'نموذج تشغيلٍ واحد.' : 'One operating model.'}</p>
        <div data-step class="bm-pillrow"><span data-glow class="bm-pill">{ar ? 'إعلانات · جمهور · أنظمة · أتمتة ← شخص واحد' : 'paid · audience · systems · automation → one'}</span></div>
      </div>
    </div>
  </section>

  <Contact lang={lang} />
</BaseLayout>

<style is:global>
  /* Biome keyframes (those not already in tokens.css) */
  @keyframes aiflow{to{background-position:300% 0}}
  @keyframes bmAuroraA{0%,100%{transform:translate3d(0,0,0) scale(1.05)}50%{transform:translate3d(-3%,2%,0) scale(1.13)}}
  @keyframes bmAuroraB{0%,100%{transform:translate3d(0,0,0) scale(1.08)}50%{transform:translate3d(4%,-2%,0) scale(1.0)}}
  @keyframes bmRingSpin{to{transform:rotate(360deg)}}
  @keyframes bmCometFly{0%{transform:translate(-32%,46%) rotate(-23deg);opacity:0}10%{opacity:1}86%{opacity:1}100%{transform:translate(128%,-34%) rotate(-23deg);opacity:0}}
  @keyframes bmDriftY{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

  /* Biome scene chrome */
  .bm-tag{position:absolute;top:84px;left:50%;transform:translateX(-50%);z-index:6;font-family:var(--mono,ui-monospace,Menlo,monospace);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-3,#6f74a0);display:flex;gap:10px;align-items:center;white-space:nowrap}
  .bm-num{color:var(--c,#2997ff);font-weight:600}
  .bm-sl{opacity:.45}
  .bm-copy{position:relative;z-index:5;width:100%;max-width:1100px;margin-inline:auto;padding-inline:clamp(20px,5vw,40px)}
  .bm-h{font-size:clamp(40px,8.5vw,108px);font-weight:850;line-height:1;letter-spacing:-.035em;color:var(--ink,#f3f4ff);opacity:0;transform:translateY(34px);will-change:transform,opacity;filter:drop-shadow(0 0 calc(var(--glow,0)*22px) rgba(var(--text-glow,170,195,255), calc(var(--glow,0)*.72)));transition:filter .18s linear}

  /* Per-line entrance technique (lib/lineanim.ts): a data-fx headline is kept
     fully opaque (the split units own the entrance); no-JS leaves plain text. */
  .bm-h[data-fx]{opacity:1;transform:none}
  .bm-h .u{display:inline-block;will-change:transform,opacity;backface-visibility:hidden}
  .bm-h .u-word{display:inline-block;white-space:nowrap}
  .bm-h .u-sp{display:inline-block;width:.28em}
  .bm-h .u-skelw{position:relative;display:inline-block}
  .bm-h .u-skel{position:absolute;inset:6% -4%;border-radius:7px;pointer-events:none;will-change:opacity,transform;
    background:linear-gradient(100deg,rgba(255,255,255,.10),rgba(255,255,255,.20),rgba(255,255,255,.10));background-size:200% 100%}
  .bm-h .u-cursor{display:inline-block;width:.5em;height:1em;vertical-align:-.12em;margin-inline-start:.04em;border-radius:2px;background:currentColor;opacity:0;will-change:opacity,transform}
  .bm-pillrow{opacity:0;transform:translateY(34px);will-change:transform,opacity;margin-top:28px}
  .bm-pill{display:inline-block;font-family:var(--font-mono);font-size:clamp(12px,1.5vw,15px);letter-spacing:.04em;color:var(--ink,#f3f4ff);padding:12px 20px;border-radius:999px;background:var(--glass-bg,rgba(255,255,255,.05));border:1px solid var(--glass-brd,rgba(255,255,255,.12));backdrop-filter:saturate(160%) blur(20px);-webkit-backdrop-filter:saturate(160%) blur(20px);box-shadow:0 0 calc(8px + var(--glow,0)*16px) rgba(255,94,138,calc((.08 + var(--glow,0)*.30)*var(--aura-k,1))), 0 0 calc(16px + var(--glow,0)*30px) rgba(162,89,255,calc((.08 + var(--glow,0)*.30)*var(--aura-k,1))), 0 0 calc(26px + var(--glow,0)*48px) rgba(41,151,255,calc((.06 + var(--glow,0)*.26)*var(--aura-k,1)));transition:box-shadow .18s linear}
  /* Arabic pills: render larger so the captions under the big headings stay clear. */
  [dir="rtl"] .bm-pill{font-size:clamp(15px,2vw,18px);padding:13px 22px}

  /* ---- Selected-work cinematic showcase (Claude Design pack #1) ----
     A horizontal strip scrubbed by vertical scroll (biome [data-track]); the
     tile nearest viewport-centre scales up + lights its accent, the watermark
     index parallaxes, and progress dots track position. Mobile = native swipe. */
  .sw-head{padding:clamp(74px,11vh,104px) clamp(20px,5vw,44px) 0;z-index:4}
  .sw-headrow{display:flex;justify-content:space-between;align-items:flex-end;gap:16px;flex-wrap:wrap;margin-top:8px}
  .sw-title{font-size:clamp(30px,6vw,60px);font-weight:900;letter-spacing:-.035em;line-height:1;margin:0;
    color:var(--ink,#f3f4ff);filter:drop-shadow(0 0 calc(var(--glow,0)*20px) rgba(var(--text-glow,170,195,255),calc(var(--glow,0)*.7)));transition:filter .18s linear}
  [dir="rtl"] .sw-title{letter-spacing:0;line-height:1.2}
  .sw-live{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono,ui-monospace,Menlo,monospace);
    font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-2,#aab0d6)}
  .sw-livedot{width:8px;height:8px;border-radius:50%;background:#30d158;box-shadow:0 0 10px #30d158;animation:swPulse 2.4s ease infinite}
  .sw-counter{direction:ltr}
  .sw-counter b{color:var(--ink,#f3f4ff)}
  @keyframes swPulse{0%,100%{opacity:1}50%{opacity:.35}}

  .sw-stripwrap{position:relative;flex:1 1 auto;min-height:0;display:flex;align-items:center;overflow:hidden}
  .sw-strip{display:flex;align-items:center;gap:clamp(18px,3vw,40px);width:max-content;
    padding-inline:max(20px,calc(50vw - min(42vw,200px)));will-change:transform}
  .sw-tile{position:relative;flex:0 0 auto;width:clamp(248px,80vw,392px);height:clamp(286px,52vh,452px);
    border-radius:24px;overflow:hidden;text-decoration:none;color:inherit;isolation:isolate;
    display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(20px,3.4vw,30px);
    background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.02));
    border:1px solid var(--glass-brd,rgba(255,255,255,.12));backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
    transform:scale(.92);opacity:.5;transition:opacity .5s var(--ease,cubic-bezier(.16,1,.3,1)),transform .5s var(--ease,cubic-bezier(.16,1,.3,1));
    box-shadow:0 30px 80px rgba(0,0,0,.4)}
  .sw-tile.act{opacity:1;transform:scale(1)}
  .sw-tile::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--a),var(--b))}
  .sw-tile::after{content:"";position:absolute;inset:0;z-index:-1;opacity:.16;transition:opacity .5s;
    background:radial-gradient(120% 90% at 50% 0%,color-mix(in srgb,var(--a) 70%,transparent),transparent 60%)}
  .sw-tile.act::after{opacity:.34}
  .sw-tile:hover{opacity:1}
  .sw-idx{position:absolute;top:clamp(-8px,-1vw,-2px);inset-inline-end:clamp(8px,2vw,20px);z-index:-1;
    font-weight:900;font-size:clamp(118px,24vw,196px);line-height:.82;letter-spacing:-.04em;will-change:transform;
    color:transparent;background:linear-gradient(160deg,var(--a),var(--b));-webkit-background-clip:text;background-clip:text;opacity:.14}
  .sw-tag{font-family:var(--mono,ui-monospace,Menlo,monospace);font-size:clamp(9.5px,2.2vw,11.5px);
    letter-spacing:.14em;text-transform:uppercase;color:var(--b);margin-bottom:auto}
  [dir="rtl"] .sw-tag{letter-spacing:.04em}
  .sw-ti{font-weight:800;letter-spacing:-.02em;line-height:1.08;font-size:clamp(21px,4.6vw,27px);margin-top:14px;color:var(--ink,#f3f4ff)}
  [dir="rtl"] .sw-ti{letter-spacing:0;line-height:1.3}
  .sw-bl{color:var(--ink-2,#aab0d6);font-size:clamp(13px,3vw,14.5px);line-height:1.5;margin-top:10px}
  .sw-foot{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-top:18px;padding-top:16px;
    border-top:1px solid var(--glass-brd,rgba(255,255,255,.12))}
  .sw-stat{font-weight:900;font-size:clamp(22px,5vw,30px);letter-spacing:-.02em;font-variant-numeric:tabular-nums;
    background:linear-gradient(120deg,var(--a),var(--b));-webkit-background-clip:text;background-clip:text;color:transparent;white-space:nowrap}
  .sw-note{font-family:var(--mono,ui-monospace,Menlo,monospace);font-size:10px;letter-spacing:.04em;color:var(--ink-3,#6f74a0);text-align:end}
  .sw-go{position:absolute;top:16px;inset-inline-end:clamp(14px,2.6vw,20px);width:32px;height:32px;border-radius:50%;
    display:grid;place-items:center;color:var(--ink,#f3f4ff);background:rgba(10,11,18,.5);border:1px solid var(--glass-brd,rgba(255,255,255,.12));
    opacity:0;transform:translateY(-6px);transition:opacity .4s,transform .4s;font-size:14px}
  .sw-tile.act .sw-go{opacity:1;transform:none}
  [dir="rtl"] .sw-tile .sw-go{transform:translateY(-6px) scaleX(-1)}
  [dir="rtl"] .sw-tile.act .sw-go{transform:scaleX(-1)}
  .sw-prog{padding:clamp(12px,2.2vh,20px) 0 clamp(18px,3.4vh,34px);display:flex;justify-content:center}
  .sw-dots{display:flex;gap:8px}
  .sw-dots i{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.16);transition:all .4s var(--ease,ease)}
  .sw-dots i.on{width:22px;border-radius:4px;background:linear-gradient(90deg,#2997ff,#a259ff)}

  /* =====================================================================
     MEANINGFUL BIOME SCENES — each line's background reads as the work it
     describes. All keyed off --p (0→1 scroll progress on [data-stage]); a few
     ambient loops keep them alive at rest. Transform/opacity only (GPU).
     ===================================================================== */
  .sc{position:absolute;left:50%;top:46%;transform:translate(-50%,-50%);pointer-events:none}

  /* ---- 01 · I run the ads → precision targeting reticle + reach ripples ---- */
  .b1{width:min(86vw,540px);height:min(86vw,540px)}
  .b1-glow{width:62vw;height:62vw;max-width:560px;max-height:560px;border-radius:50%;filter:blur(60px);
    background:radial-gradient(circle,rgba(41,151,255,.5),transparent 64%);
    transform:translate(-50%,-50%) scale(calc(.6 + var(--p,0)*.7));opacity:calc(.16 + var(--p,0)*.48)}
  .b1 span{position:absolute;left:50%;top:50%}
  .b1-reach{width:30%;height:30%;border-radius:50%;border:1.5px solid rgba(100,210,255,.55);
    transform:translate(-50%,-50%) scale(.34);opacity:0;animation:b1reach 4.8s ease-out infinite}
  .b1-reach.r2{animation-delay:1.6s}.b1-reach.r3{animation-delay:3.2s}
  @keyframes b1reach{0%{transform:translate(-50%,-50%) scale(.34);opacity:calc(.12 + var(--p,0)*.5)}
    100%{transform:translate(-50%,-50%) scale(2.7);opacity:0}}
  .b1-sweep{width:48%;height:48%;border-radius:50%;
    background:conic-gradient(from 0deg,transparent 0 300deg,rgba(100,210,255,.45) 348deg,rgba(100,210,255,.04) 360deg);
    -webkit-mask:radial-gradient(circle,transparent 6%,#000 56%,transparent 100%);
    mask:radial-gradient(circle,transparent 6%,#000 56%,transparent 100%);
    opacity:calc(.16 + var(--p,0)*.64);animation:b1spin 4.4s linear infinite}
  @keyframes b1spin{from{transform:translate(-50%,-50%) rotate(0)}to{transform:translate(-50%,-50%) rotate(360deg)}}
  .b1-cross.h{width:48%;height:1.5px;transform:translate(-50%,-50%);opacity:calc(.08 + var(--p,0)*.62);
    background:linear-gradient(90deg,transparent,rgba(100,210,255,.6),transparent)}
  .b1-cross.v{width:1.5px;height:48%;transform:translate(-50%,-50%);opacity:calc(.08 + var(--p,0)*.62);
    background:linear-gradient(180deg,transparent,rgba(100,210,255,.6),transparent)}
  .b1-ring{width:48%;height:48%;border-radius:50%;
    border:2px solid color-mix(in srgb,#2997ff calc(38% + var(--p,0)*62%),transparent);
    transform:translate(-50%,-50%) scale(calc(1.5 - var(--p,0)*.62));
    box-shadow:0 0 calc(var(--p,0)*30px) rgba(41,151,255,.5);opacity:calc(.28 + var(--p,0)*.72)}
  .b1-dot{width:calc(9px + var(--p,0)*13px);height:calc(9px + var(--p,0)*13px);border-radius:50%;
    transform:translate(-50%,-50%);background:radial-gradient(circle,#fff,#64d2ff 55%,transparent);
    box-shadow:0 0 calc(10px + var(--p,0)*26px) #2997ff;opacity:calc(.4 + var(--p,0)*.6)}

  /* ---- 04 · I shape the brand → scattered dots converge onto one ring/mark ---- */
  .b4{width:min(80vw,460px);height:min(80vw,460px);overflow:visible}
  .b4-glow{width:54vw;height:54vw;max-width:480px;max-height:480px;border-radius:50%;filter:blur(64px);
    background:radial-gradient(circle,rgba(191,90,242,.42),transparent 66%);
    transform:translate(-50%,-50%) scale(calc(.7 + var(--p,0)*.5));opacity:calc(.2 + var(--p,0)*.38)}
  .b4-ring{position:absolute;left:50%;top:50%;width:36vmin;height:36vmin;border-radius:50%;
    border:1px solid color-mix(in srgb,#bf5af2 calc(16% + var(--p,0)*54%),transparent);
    transform:translate(-50%,-50%) scale(calc(.62 + var(--p,0)*.38));opacity:calc(var(--p,0)*.85)}
  .b4-dot{position:absolute;left:50%;top:50%;width:7px;height:7px;border-radius:50%;
    background:radial-gradient(circle,#fff,#bf5af2 58%,transparent);
    box-shadow:0 0 calc(4px + var(--p,0)*12px) #bf5af2;opacity:calc(.35 + var(--p,0)*.65);
    transform:translate(-50%,-50%)
      translate(calc((var(--sx)*(1 - var(--p,0)) + var(--ex)*var(--p,0))*1vmin),
                calc((var(--sy)*(1 - var(--p,0)) + var(--ey)*var(--p,0))*1vmin))}
  .b4-core{position:absolute;left:50%;top:50%;border-radius:50%;
    width:calc(6px + var(--p,0)*10px);height:calc(6px + var(--p,0)*10px);transform:translate(-50%,-50%);
    background:radial-gradient(circle,#fff,#bf5af2 60%,transparent);
    box-shadow:0 0 calc(8px + var(--p,0)*26px) #bf5af2;opacity:calc(var(--p,0)*.9)}

  /* ---- 06 · I automate the rest with AI → a self-running input→AI→output line ---- */
  .b6{width:min(92vw,640px);height:200px}
  .b6-glow{width:70vw;height:30vw;max-width:600px;max-height:240px;border-radius:50%;filter:blur(56px);
    background:radial-gradient(closest-side,rgba(255,214,10,.34),transparent);
    transform:translate(-50%,-50%) scale(calc(.7 + var(--p,0)*.5));opacity:calc(.14 + var(--p,0)*.36)}
  .b6-rail{position:absolute;top:50%;left:9%;right:9%;height:2px;transform:translateY(-50%);
    background:linear-gradient(90deg,transparent,color-mix(in srgb,#ffd60a 65%,transparent),transparent);
    opacity:calc(.3 + var(--p,0)*.6)}
  .b6-node{position:absolute;top:50%;width:36px;height:36px;border-radius:10px;transform:translate(-50%,-50%);
    border:1px solid color-mix(in srgb,#ffd60a calc(40% + var(--p,0)*40%),transparent);
    background:color-mix(in srgb,#ffd60a 12%,transparent);opacity:calc(.45 + var(--p,0)*.55)}
  .b6-node.in{left:9%}
  .b6-node.out{left:91%;border-color:color-mix(in srgb,#30d158 calc(40% + var(--p,0)*40%),transparent);
    background:color-mix(in srgb,#30d158 12%,transparent)}
  .b6-core{position:absolute;top:50%;left:50%;width:58px;height:58px;border-radius:50%;
    transform:translate(-50%,-50%) scale(calc(.85 + var(--p,0)*.3));
    background:radial-gradient(circle,#fff,rgba(255,214,10,.85) 38%,rgba(255,159,10,.2) 70%,transparent);
    box-shadow:0 0 calc(12px + var(--p,0)*34px) rgba(255,214,10,.6);animation:corePulse 4s ease-in-out infinite}
  .b6-core i{position:absolute;inset:-8px;border-radius:50%;border:1.5px dashed rgba(255,214,10,.55);
    animation:b6spin 7s linear infinite}
  @keyframes b6spin{to{transform:rotate(360deg)}}
  .b6-tok{position:absolute;top:50%;left:9%;width:10px;height:10px;margin:-5px 0 0 -5px;border-radius:50%;
    background:radial-gradient(circle,#fff,#ffd60a 60%,transparent);box-shadow:0 0 10px #ffd60a;
    animation:b6flow 3.6s linear infinite}
  .b6-tok.t2{animation-delay:.72s}.b6-tok.t3{animation-delay:1.44s}.b6-tok.t4{animation-delay:2.16s}.b6-tok.t5{animation-delay:2.88s}
  @keyframes b6flow{
    0%{left:9%;opacity:0;transform:scale(.6)}
    8%{opacity:calc(.35 + var(--p,0)*.55)}
    48%{transform:scale(1)}
    50%{left:50%;transform:scale(.35)}
    54%{transform:scale(1)}
    92%{left:91%;opacity:calc(.35 + var(--p,0)*.55)}
    100%{left:91%;opacity:0;transform:scale(.6)}}

  /* ---- 07 · I put it on the web → a live site loads in a browser ---- */
  .b7{width:min(88vw,540px);height:min(74vw,400px)}
  .b7-globe{width:66vw;height:66vw;max-width:520px;max-height:520px;border-radius:50%;
    border:1px solid rgba(117,116,238,.16);
    background:repeating-linear-gradient(0deg,transparent 0 13px,rgba(117,116,238,.09) 13px 14px),
      repeating-linear-gradient(90deg,transparent 0 13px,rgba(117,116,238,.09) 13px 14px);
    -webkit-mask:radial-gradient(circle,#000 48%,transparent 72%);mask:radial-gradient(circle,#000 48%,transparent 72%);
    transform:translate(-50%,-50%) scale(calc(.8 + var(--p,0)*.3));opacity:calc(.1 + var(--p,0)*.3)}
  .b7-win{position:absolute;left:50%;top:50%;width:100%;transform:translate(-50%,-50%) scale(calc(.92 + var(--p,0)*.08));
    border-radius:14px;border:1px solid color-mix(in srgb,#7574ee 45%,var(--glass-brd));
    background:color-mix(in srgb,#0e0e18 70%,transparent);backdrop-filter:blur(7px);-webkit-backdrop-filter:blur(7px);
    overflow:hidden;opacity:calc(.25 + var(--p,0)*.75);box-shadow:0 0 calc(var(--p,0)*44px) rgba(117,116,238,.4)}
  .b7-bar{display:flex;align-items:center;gap:7px;padding:11px 13px;border-bottom:1px solid rgba(255,255,255,.08)}
  .b7-bar i{width:10px;height:10px;border-radius:50%;flex:0 0 auto}
  .b7-bar i:nth-child(1){background:#ff5f57}.b7-bar i:nth-child(2){background:#febc2e}.b7-bar i:nth-child(3){background:#28c840}
  .b7-url{height:15px;border-radius:8px;margin-inline-start:8px;background:rgba(255,255,255,.10);width:calc(18% + var(--p,0)*64%)}
  .b7-body{padding:18px 20px 26px;display:flex;flex-direction:column;gap:12px;min-height:118px}
  .b7-block{height:13px;border-radius:7px;
    background:linear-gradient(90deg,color-mix(in srgb,#7574ee 55%,transparent),color-mix(in srgb,#7574ee 12%,transparent))}
  .b7-block.a{width:66%;opacity:clamp(0,(var(--p,0) - .18)*6,1);transform:translateY(calc((1 - clamp(0,(var(--p,0) - .18)*6,1))*12px))}
  .b7-block.b{width:88%;opacity:clamp(0,(var(--p,0) - .34)*6,1);transform:translateY(calc((1 - clamp(0,(var(--p,0) - .34)*6,1))*12px))}
  .b7-block.c{width:48%;opacity:clamp(0,(var(--p,0) - .5)*6,1);transform:translateY(calc((1 - clamp(0,(var(--p,0) - .5)*6,1))*12px))}
  .b7-live{position:absolute;right:16px;bottom:14px;font-family:var(--font-mono);font-size:12px;font-weight:600;
    letter-spacing:.04em;color:#30d158;padding:5px 11px;border-radius:999px;
    border:1px solid color-mix(in srgb,#30d158 45%,transparent);background:color-mix(in srgb,#30d158 14%,transparent);
    opacity:clamp(0,(var(--p,0) - .72)*7,1);transform:scale(calc(.8 + clamp(0,(var(--p,0) - .72)*7,1)*.2));
    box-shadow:0 0 calc(clamp(0,(var(--p,0) - .72)*7,1)*16px) rgba(48,209,88,.5)}
  [dir="rtl"] .b7-live{right:auto;left:16px}

  /* The biomes own the scroll; the legacy rail/progress aren't needed here. */
  @media (prefers-reduced-motion:reduce){
    [data-pin]{height:auto !important}
  }

  /* ---- Phones ----
     The pinned biomes were tuned for tall desktop viewports; at ~300vh each they
     leave long empty stretches on a phone. Tighten them so content stays on
     screen. And the Selected-Work strip's horizontal scrub pushes the 330px
     cards off the side of a narrow screen (they "disappear") — on mobile, stack
     all 9 cards vertically instead. */
  @media (max-width:820px){
    /* 1. iOS viewport fix: use dvh so the biome stage always fills the full
          dynamic viewport — even after the address bar collapses on scroll.
          !important overrides the inline height:100svh on every [data-stage]. */
    [data-stage]{height:100dvh !important}
    /* Shorter pins on phones: content now reveals near the top of each stage
       (biome.ts mobile timing), so 150vh is enough hold to watch the biome
       drift without long dead scroll between scenes. */
    section[data-pin]{height:150vh !important}

    /* Selected-Work showcase → native horizontal swipe on phones. The biome
       scrub is skipped (biome.ts bails ≤820px); overflow-x + scroll-snap take
       over, and every tile is fully visible (no centre-scale focus). */
    #work[data-pin]{height:auto !important}
    #work .sw-head{padding-top:54px !important}
    #work .sw-stage{
      position:relative !important;height:auto !important;min-height:0 !important;
      display:flex !important;flex-direction:column !important;gap:16px !important;
      overflow:visible !important;padding-bottom:24px !important;
    }
    #work .sw-stripwrap{overflow:visible !important;display:block !important}
    #work .sw-strip{
      width:auto !important;transform:none !important;
      overflow-x:auto;-webkit-overflow-scrolling:touch;
      scroll-snap-type:x mandatory;scroll-padding-inline:20px;
      gap:14px !important;padding-inline:20px !important;scrollbar-width:none;
    }
    #work .sw-strip::-webkit-scrollbar{display:none}
    #work .sw-tile{
      flex:0 0 82vw !important;width:82vw !important;
      height:auto !important;min-height:360px !important;
      scroll-snap-align:center;opacity:1 !important;transform:none !important;
    }
    #work .sw-tile .sw-go{opacity:1;transform:none}
