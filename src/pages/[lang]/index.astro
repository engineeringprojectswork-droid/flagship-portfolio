  /* ---- Phones ----
     The pinned biomes were tuned for tall desktop viewports; at ~300vh each they
     leave long empty stretches on a phone. Tighten them so content stays on
     screen. And the Selected-Work strip's horizontal scrub pushes the 330px
     cards off the side of a narrow screen (they "disappear") — on mobile, stack
     all 9 cards vertically instead. */
  @media (max-width:820px){
    /* 1. iOS viewport fix: use dvh so the biome stage always fills the full
          dynamic viewport — even after the address bar collapses on scroll.
          !important overrides the inline height:100svh on every [data-stage]. */
    [data-stage]{height:100dvh !important}
    /* Shorter pins on phones: content now reveals near the top of each stage
       (biome.ts mobile timing), so 150vh is enough hold to watch the biome
       drift without long dead scroll between scenes. */
    section[data-pin]{height:150vh !important}

    /* The biome scene tag sits absolute at top:84px — fine inside a full-height
       sticky stage, but the #work stage becomes a static block on mobile, so the
       tag would overlap "Selected work." Pin it back into normal flow there. */
    #work .bm-tag{position:static !important;transform:none !important;justify-content:flex-start;margin-bottom:4px}

    /* 2. Selected-Work strip: native horizontal swipe instead of stacked cards.
          The JS transform is blocked (biome.ts skips track.style.transform when
          innerWidth ≤ 820); overflow-x:auto + scroll-snap take over. */
    #work[data-pin]{height:auto !important}
    #work [data-stage]{
      position:relative !important;height:auto !important;min-height:0 !important;
      display:flex !important;flex-direction:column !important;gap:20px !important;
      overflow:visible !important;padding-block:54px !important;
    }
    #work [data-track]{
      flex-wrap:nowrap !important;width:100% !important;transform:none !important;
      overflow-x:auto;-webkit-overflow-scrolling:touch;
      scroll-snap-type:x mandatory;
      scroll-padding-inline:clamp(20px,5vw,40px);
      gap:14px !important;scrollbar-width:none;
    }
    #work [data-track]::-webkit-scrollbar{display:none}
    #work .wcard{
      flex:0 0 82vw !important;width:82vw !important;
      height:auto !important;min-height:380px !important;
      scroll-snap-align:start;
    }
    /* cards are immediately visible — no stagger animation in swipe mode */
    html.js #work .wcard{opacity:1 !important;transform:none !important;transition:none !important}
    html.js #work .wcard.in{opacity:1 !important;transform:none !important}
    /* hide the "scroll to scrub →" desktop hint; the swipe UX is self-evident */
    .strip-hint{display:none}
  }
</style>

<script>
  import { initBiome } from '../../lib/biome';
  let teardown: (() => void) | undefined;
  // Mobile: cards are in a native swipe strip — immediately visible, no stagger.
  function revealWorkCards() {
    if (window.innerWidth > 820) return;
    document.querySelectorAll<HTMLElement>('#work .wcard').forEach((c) => c.classList.add('in'));
  }
  function boot() {
    teardown?.();
    teardown = initBiome();
    revealWorkCards();
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
